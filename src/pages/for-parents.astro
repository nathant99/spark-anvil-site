---
import BaseLayout from '~/layouts/BaseLayout.astro';

const dontDo = [
  { icon: '🚫', label: 'No ads',
    detail: 'Zero advertising, ever. No banner ads, no rewarded video, no sponsored content.' },
  { icon: '💸', label: 'No in-app purchases',
    detail: 'You pay once. Your kid can\'t accidentally buy anything. No power-ups, no premium currency, no upgrade nags.' },
  { icon: '👁️', label: 'No tracking',
    detail: 'No analytics SDKs tracking your kid. We use Plausible (privacy-first, no cookies) on our website only — never inside the apps.' },
  { icon: '🔗', label: 'No third-party SDKs',
    detail: 'The apps don\'t embed Facebook, Google, AppsFlyer, or any other tracking framework. Just Apple\'s own frameworks plus our open-source ForgeKit library.' },
  { icon: '☁️', label: 'No data leaves the device',
    detail: 'All your kid\'s progress, settings, and AI-generated content stays on their device. Nothing uploads to our servers (we don\'t even have user-facing servers).' },
];
---

<BaseLayout
  title="For Parents"
  description="Spark & Anvil apps for kids ages 5–14 — all free, forever. No ads, no in-app purchases, no tracking. COPPA compliant under the 2026 FTC amendments."
>
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-12 text-center">
    <span class="inline-block px-3 py-1 mb-4 bg-anvil/10 dark:bg-warm/15 text-anvil dark:text-warm text-xs font-bold uppercase tracking-wider rounded-full">Mission-driven non-profit</span>
    <h1 class="font-brand font-bold text-4xl md:text-5xl text-anvil dark:text-warm mb-4">
      Apps your kid can actually use.
    </h1>
    <p class="text-xl text-anvil/70 dark:text-warm/70 max-w-2xl mx-auto">
      Privacy you can actually verify. <span class="text-forge">Designed for face-to-face play.</span>
    </p>
    <p class="mt-4 text-sm text-anvil/60 dark:text-warm/60 max-w-2xl mx-auto leading-relaxed">
      Spark &amp; Anvil is restructuring as a 501(c)(3) non-profit. All apps remain free forever.
      <a href="/mission" class="underline hover:text-forge">Read the mission →</a>
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-6 pb-20">
    <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil dark:text-warm mb-6">
      What we don&apos;t do
    </h2>
    <ul class="space-y-5">
      {dontDo.map(item => (
        <li class="flex gap-4 p-5 bg-white dark:bg-anvil/40 rounded-xl border border-anvil/10 dark:border-warm/15">
          <span class="text-3xl flex-shrink-0">{item.icon}</span>
          <div>
            <h3 class="font-brand font-bold text-lg mb-1">{item.label}</h3>
            <p class="text-anvil/70 dark:text-warm/70 leading-relaxed">{item.detail}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <section class="bg-anvil/5 dark:bg-warm/5 py-16">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil dark:text-warm mb-6">
        How we handle data
      </h2>
      <div class="prose prose-anvil max-w-none space-y-4 text-anvil/80 dark:text-warm/80 leading-relaxed">
        <p>
          Spark &amp; Anvil apps are <strong>on-device first</strong>. Your kid&apos;s progress, settings,
          AI-generated content, and any creations they make stay on their iPhone, iPad, or Mac.
        </p>
        <p>
          We use Apple&apos;s SwiftData framework for local storage, FoundationModels for on-device AI
          generation (no cloud calls), and SwiftUI for the interface. We don&apos;t operate
          any user-facing servers — there is literally no backend collecting your kid&apos;s data.
        </p>
        <p>
          For our company website (this site), we use <a href="https://plausible.io" target="_blank" rel="noopener">Plausible</a> —
          a privacy-first, cookie-free analytics tool. It tells us roughly how many people visited each page.
          It does not track individuals, store cookies, or sell data.
        </p>
        <p>
          Read the <a href="/privacy">full privacy policy</a> for details. The parent-friendly summary is at the top;
          the comprehensive legal version follows.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil dark:text-warm mb-6">
      A letter to parents
    </h2>
    <div class="prose prose-anvil max-w-none space-y-4 text-anvil/80 dark:text-warm/80 leading-relaxed">
      <p class="text-lg">
        <em>(Founder note — to be supplied.)</em>
      </p>
      <p class="text-anvil/50 dark:text-warm/50 text-sm">
        Modeled on Sago Mini&apos;s &quot;Letter to Parents&quot;. Will cover: why we built Spark &amp; Anvil,
        the values that guide app design, how to think about screen time with our apps,
        and an invitation for parents to co-play.
      </p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 pb-20">
    <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil dark:text-warm mb-6">
      Frequently asked questions
    </h2>
    <dl class="space-y-6">
      <div>
        <dt class="font-brand font-bold text-lg mb-2">Are the apps free?</dt>
        <dd class="text-anvil/70 dark:text-warm/70 leading-relaxed">
          <strong>Yes — all our apps are free forever.</strong> No subscriptions, no in-app purchases,
          no recurring fees, no ads. Download as many as you want; they cost nothing.
        </dd>
      </div>
      <div>
        <dt class="font-brand font-bold text-lg mb-2">Then how does Spark &amp; Anvil make money?</dt>
        <dd class="text-anvil/70 dark:text-warm/70 leading-relaxed">
          Our only revenue stream is a teacher-led classroom marketplace launching Q1 2027 — live, small-group classes
          taught by vetted teachers using our apps as the curriculum. You pay the teacher; we take 15%.
          <strong>Everything else is free, forever. Every app. Every multiplayer feature. No subscriptions. No in-app
          purchases. No ads. No tracking.</strong> We never monetize children directly.
        </dd>
      </div>
      <div>
        <dt class="font-brand font-bold text-lg mb-2">What ages are these for?</dt>
        <dd class="text-anvil/70 dark:text-warm/70 leading-relaxed">
          <strong>Two age tiers, all free.</strong> Our main portfolio targets <strong>ages 9–14</strong> (135 apps, most shipping now).
          We're also rolling out a <strong>Younger Cluster for ages 5–8</strong> in 2027 (6 apps in flight — TinyLetters, CountingPals,
          TaleTrail, HuggyHabits, BugsCamp, MelodyMice). Each ages-5-8 app has a mascot that's a "younger sibling" to one
          of our ages-9-14 mascots, so kids can graduate from one portfolio to the other around age 8.
          The exact age band is listed on each app&apos;s page.
        </dd>
      </div>
      <div>
        <dt class="font-brand font-bold text-lg mb-2">Do you use AI? Should I be worried?</dt>
        <dd class="text-anvil/70 dark:text-warm/70 leading-relaxed">
          Yes, we use Apple&apos;s on-device <em>FoundationModels</em> for things like AI mentors,
          hint generation, and adaptive feedback. All AI runs <strong>on the device</strong> —
          nothing your kid types or generates is sent to a server. There&apos;s no cloud-based AI
          processing personal data.
        </dd>
      </div>
      <div>
        <dt class="font-brand font-bold text-lg mb-2">What about COPPA?</dt>
        <dd class="text-anvil/70 dark:text-warm/70 leading-relaxed">
          We comply with the 2026 FTC COPPA amendments (effective April 22, 2026).
          We don&apos;t collect personal information from kids under 13. We don&apos;t share data
          for advertising (we don&apos;t share data at all). We provide verifiable parental consent
          flows for any features that require it. Read the <a href="/privacy">full policy</a>.
        </dd>
      </div>
    </dl>
  </section>
</BaseLayout>
