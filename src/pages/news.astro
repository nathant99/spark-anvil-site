---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { apps } from '~/data/apps.generated';

const milestones = [
  {
    date: 'May 2026',
    title: '141 apps milestone',
    body: `Spark & Anvil's portfolio reached ${apps.length} free-forever educational iOS apps across 5 verticals (STEM, STEAM, Academics, DIR/FEDC, Special Interest). The Younger Cluster (ages 5-8: TinyLetters, CountingPals, TaleTrail, HuggyHabits, BugsCamp, MelodyMice) joined the tween portfolio (ages 9-14) with full mascot-continuity arc.`,
    type: 'product',
  },
  {
    date: 'May 2026',
    title: '"Free Forever" pledge',
    body: 'All Spark & Anvil apps are free, forever — no ads, no in-app purchases, no tracking, no subscriptions. Multiplayer is free too. Revenue comes from a single source: an optional teacher-led classroom marketplace launching Q1 2027. We never monetize children directly.',
    type: 'announcement',
  },
  {
    date: 'May 2026',
    title: 'Distributed-Narrative cluster spawned',
    body: '6 net-new app concepts inspired by distributed-narrative pedagogy research — tactical patterns as recurring character archetypes: GambitTales (chess), StoneSong (Go), GeneralsTale (Xiangqi), MotifLab (composition), PipQuest (backgammon), DealTales (bridge). Each features named characters embodying core tactical motifs so kids learn by following the story.',
    type: 'product',
  },
  {
    date: 'Coming Q3 2026',
    title: 'kidSAFE+ COPPA Certified application',
    body: 'Spark & Anvil submits for kidSAFE+ COPPA Certified status — granting COPPA Safe Harbor protection ahead of the April 22, 2026 FTC amendments. Common Sense Privacy Seal application parallel.',
    type: 'milestone',
  },
  {
    date: 'Coming Q4 2026',
    title: '50 paid pilot teachers',
    body: 'Spark & Anvil recruits the first 50 paid-pilot teachers ($500-2,000 onboarding stipend each) to validate the teacher-led classroom marketplace ahead of public Q1 2027 launch.',
    type: 'milestone',
  },
  {
    date: 'Coming Q1 2027',
    title: 'Classroom marketplace public launch',
    body: 'Spark & Anvil opens the curated teacher-led classroom marketplace. Teachers earn 85% of class fees. Curated class slots from each app\'s curriculum. ForgeClassroom: cohort sync inside each app + teacher dashboard + AI co-pilot prompts.',
    type: 'milestone',
  },
  {
    date: 'Coming Q2-Q3 2027',
    title: 'ESA acceptance in 6 US states',
    body: 'Florida, Arizona, Iowa, Utah, Arkansas, Texas — Spark & Anvil becomes an approved Education Savings Account vendor in these states. Combined with free apps: families pay zero out-of-pocket cost. Q2-Q3 2027 expansion adds 12 more states.',
    type: 'milestone',
  },
  {
    date: 'Coming Q3-Q4 2027',
    title: 'UK launch',
    body: 'Spark & Anvil expands to the United Kingdom (Year-2 international priority). UK Age Appropriate Design Code compliant. Coordinated with UK back-to-school 2027.',
    type: 'milestone',
  },
];

const typeColors = {
  product: 'bg-forge/10 text-forge border-forge/30',
  announcement: 'bg-spark/20 text-anvil border-spark/40',
  milestone: 'bg-slate/10 text-slate border-slate/30',
};
---

<BaseLayout
  title="News & Milestones"
  description="Spark & Anvil news, milestones, and product announcements — from the 136-app portfolio launch through the Q1 2027 classroom marketplace and beyond."
>
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-12">
    <h1 class="font-brand font-bold text-4xl md:text-5xl text-anvil mb-4">
      News & Milestones
    </h1>
    <p class="text-xl text-anvil/70 leading-relaxed">
      Product launches, partnerships, and milestones as Spark & Anvil rolls out
      the free-forever educational app portfolio + teacher marketplace.
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-24">
    <ol class="relative border-l-2 border-anvil/15 pl-8 space-y-12">
      {milestones.map(m => (
        <li class="relative">
          <span class="absolute -left-[42px] top-1 w-6 h-6 rounded-full bg-warm border-2 border-anvil/30"></span>
          <div class="flex flex-wrap items-baseline gap-3 mb-2">
            <span class={`inline-block px-2 py-0.5 text-xs font-bold uppercase tracking-wider rounded border ${typeColors[m.type as keyof typeof typeColors]}`}>
              {m.type}
            </span>
            <span class="text-sm text-anvil/60 font-medium">{m.date}</span>
          </div>
          <h2 class="font-brand font-bold text-2xl text-anvil mb-2">{m.title}</h2>
          <p class="text-anvil/80 leading-relaxed">{m.body}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="bg-anvil/5 py-12">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-brand font-bold text-2xl text-anvil mb-3">For journalists</h2>
      <p class="text-anvil/70 mb-6">
        Press kit, founder bio, and brand asset bundle available at <a href="mailto:press@spark-and-anvil.com" class="text-forge-text underline">press@spark-and-anvil.com</a>.
      </p>
    </div>
  </section>
</BaseLayout>
