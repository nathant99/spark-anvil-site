---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { apps, type AppData } from '~/data/apps.generated';
import { verticals } from '~/data/site';
import { renderInline } from '~/lib/markdown';
import { modes, scoreLabel, type ModeKey } from '~/data/modes';
import castManifest from '~/data/cast-manifest.json';

export async function getStaticPaths() {
  return apps.map(app => ({
    params: { slug: app.slug },
    props: { app },
  }));
}

interface Props {
  app: AppData;
}

const { app } = Astro.props;
const verticalName = verticals.find(v => v.id === app.vertical)?.name ?? app.vertical;

// Cast-portrait resolution — mirror labsmith/scripts/gen_cast_portraits.py slug rule
function slugChar(name: string): string {
  return name
    .toLowerCase()
    .replace(/&/g, '-and-')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '') || 'char';
}
const portraitSet = new Set<string>(castManifest as string[]);
function portraitFor(charName: string): string | null {
  const key = `${app.slug}/${slugChar(charName)}.webp`;
  return portraitSet.has(key) ? `/cast/${key}` : null;
}
---

<BaseLayout
  title={app.name}
  description={app.tagline}
  ogImage={app.iconPath ?? '/brand/lockup.png'}
>
  <!-- Hero -->
  <section
    class="py-16 md:py-24"
    style={`background-color: ${app.heroColor}; color: white;`}
  >
    <div class="max-w-4xl mx-auto px-6 grid md:grid-cols-2 gap-8 items-center">
      <div>
        <a href="/apps" class="inline-block text-sm font-bold text-white/80 hover:text-white mb-4">
          ← All apps
        </a>
        <p class="text-sm uppercase tracking-wider text-white/70 font-medium mb-2">
          {verticalName}
        </p>
        <h1 class="font-brand font-bold text-5xl md:text-6xl mb-4">{app.name}</h1>
        <p class="text-xl text-white/90 leading-relaxed">{app.tagline}</p>
        {app.playTogether && (
          <span class="inline-flex items-center gap-1.5 mt-4 px-3 py-1 bg-white/20 backdrop-blur text-white text-sm font-bold rounded-full">
            <span>👥</span>
            Pass-and-play available
          </span>
        )}
      </div>
      <div class="flex items-center justify-center">
        {(app.iconHeroPath ?? app.iconPath) ? (
          <img
            src={app.iconHeroPath ?? app.iconPath ?? ''}
            alt={`${app.name} app icon`}
            class="w-48 h-48 md:w-64 md:h-64 rounded-3xl shadow-2xl"
          />
        ) : (
          <div class="w-48 h-48 md:w-64 md:h-64 rounded-3xl bg-white/20 dark:bg-warm/10 flex items-center justify-center text-white/50 text-sm">
            Icon coming soon
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Mascot (if available) -->
  {app.mascotPath && (
    <section class="bg-anvil/5 dark:bg-warm/5 py-16">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-10">
          <h2 class="font-brand font-bold text-3xl md:text-4xl text-anvil mb-3">Meet your mentor</h2>
          <p class="text-anvil/80 dark:text-warm/80 leading-relaxed max-w-2xl mx-auto">
            Every Spark &amp; Anvil app has a friendly mentor character that demonstrates,
            praises, and patiently scaffolds learning. On-device AI personalizes the
            mentor&apos;s responses to your kid&apos;s progress — never connecting to a server,
            never collecting data.
          </p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4 max-w-3xl mx-auto">
          {['demonstrating', 'praising', 'thinking', 'working', 'encouraging'].map(pose => (
            <figure class="text-center">
              <div
                class="aspect-square rounded-2xl overflow-hidden flex items-center justify-center"
                style={`background-color: ${app.heroColor}20`}
              >
                <img
                  src={`/apps/${app.slug}/mascots/${pose}.webp`}
                  alt={`${app.name} mascot ${pose}`}
                  class="w-full h-full object-contain p-2"
                  loading="lazy"
                  onerror="this.parentElement.parentElement.style.display='none'"
                />
              </div>
              <figcaption class="mt-2 text-xs uppercase tracking-wider text-anvil/60 dark:text-warm/60 font-medium">
                {pose}
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Status + standards strip -->
  <section class="max-w-4xl mx-auto px-6 py-12">
    <div class="flex flex-wrap items-center gap-3">
      {app.wave && (
        <span class="px-3 py-1 bg-forge/10 dark:bg-forge-light/15 text-forge-text dark:text-forge-light text-xs font-bold rounded-full uppercase tracking-wider">
          Wave {app.wave} implementing
        </span>
      )}
      {!app.implementing && (
        <span class="px-3 py-1 bg-anvil/10 dark:bg-warm/10 text-anvil/60 dark:text-warm/60 text-xs font-bold rounded-full uppercase tracking-wider">
          In planning
        </span>
      )}
      {app.hasM9Accessories && (
        <span class="px-3 py-1 bg-spark/30 dark:bg-spark/40 text-anvil dark:text-warm text-xs font-bold rounded-full">
          8 themed avatar accessories
        </span>
      )}
      <span class="px-3 py-1 bg-anvil/5 dark:bg-warm/5 text-anvil/70 dark:text-warm/70 text-xs font-medium rounded-full">
        Swift 6 · SwiftUI · FoundationModels
      </span>
      {app.standards.map(s => (
        <span class="px-3 py-1 bg-anvil/5 dark:bg-warm/5 text-anvil/70 dark:text-warm/70 text-xs font-medium rounded-full">
          {s}
        </span>
      ))}
      <span class="ml-auto inline-flex items-center gap-2 text-xs text-anvil/60 dark:text-warm/60">
        Hero color:
        <span class="w-4 h-4 rounded border border-anvil/20 dark:border-warm/25" style={`background-color: ${app.heroColor}`}></span>
        <code class="text-xs">{app.heroColor}</code>
      </span>
    </div>

    {/* Engagement modality badges — Learn / Play / Create cross-cutting axis */}
    {app.modes && (
      <div class="mt-6 flex flex-wrap items-center gap-2">
        <span class="text-xs uppercase tracking-wider text-anvil/50 dark:text-warm/50 font-medium mr-1">
          Engagement:
        </span>
        {modes
          .map(m => ({ m, score: app.modes![m.key as ModeKey] }))
          .filter(({ score }) => score >= 2)
          .sort((a, b) => b.score - a.score)
          .map(({ m, score }) => (
            <a
              href={`/apps?mode=${m.key}`}
              class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider text-white shadow-sm hover:opacity-90 transition-opacity"
              style={`background-color: ${m.hex}`}
              title={`${m.label} — ${scoreLabel[score as 0|1|2|3]} mode. Click to see all ${m.label} apps.`}
            >
              <span aria-hidden="true">●</span>
              {m.label}
              <span class="font-medium opacity-80">· {scoreLabel[score as 0|1|2|3]}</span>
            </a>
          ))}
        {(Object.values(app.modes).every(s => s < 2)) && (
          <span class="text-xs italic text-anvil/40 dark:text-warm/40">Modes pending</span>
        )}
      </div>
    )}
  </section>

  <!-- Long tagline (from User Guide if available) -->
  {app.longTagline && (
    <section class="max-w-3xl mx-auto px-6 py-12">
      <p class="text-xl text-anvil/80 dark:text-warm/80 leading-relaxed" set:html={renderInline(app.longTagline)}></p>
    </section>
  )}

  <!-- Distributed-narrative cast — named recurring characters that embody specific curricular concepts -->
  {app.dnCast && app.dnCast.members.length > 0 && (
    <section class="bg-forge/5 dark:bg-forge-light/10 py-16 border-y border-forge/15 dark:border-forge-light/20">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-8">
          <p class="text-xs uppercase tracking-wider text-forge dark:text-forge-light font-bold mb-2">
            Distributed-narrative cast
          </p>
          <h2 class="font-brand font-bold text-3xl text-anvil dark:text-warm mb-3">
            Meet the cast
          </h2>
          {app.dnCast.intro && (
            <p class="text-anvil/70 dark:text-warm/70 leading-relaxed max-w-2xl mx-auto">
              {app.dnCast.intro}
            </p>
          )}
        </div>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
          {app.dnCast.members.map(m => {
            const portrait = portraitFor(m.name);
            return (
              <div class="p-4 bg-white dark:bg-anvil/40 rounded-xl border border-anvil/10 dark:border-warm/15 flex gap-3 items-start">
                {portrait ? (
                  <div
                    class="w-14 h-14 rounded-full overflow-hidden border-2 border-warm flex-shrink-0"
                    style={`background-color: ${app.heroColor}`}
                  >
                    <img
                      src={portrait}
                      alt={`${m.name} portrait`}
                      class="w-full h-full object-contain"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div
                    class="w-14 h-14 rounded-full flex-shrink-0 flex items-center justify-center font-brand font-bold text-white text-lg"
                    style={`background-color: ${app.heroColor}`}
                  >
                    {m.name.charAt(0)}
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <h3 class="font-brand font-bold text-anvil dark:text-warm mb-1 leading-tight">{m.name}</h3>
                  <p class="text-xs text-anvil/70 dark:text-warm/70 leading-snug">{m.role}</p>
                </div>
              </div>
            );
          })}
        </div>
        <p class="text-center mt-6">
          <a href="/method" class="text-forge dark:text-forge-light text-sm font-bold underline hover:no-underline">
            What&apos;s distributed-narrative methodology? →
          </a>
        </p>
      </div>
    </section>
  )}

  <!-- What's inside — features extracted from User Guide, fall back to generic 3-up -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="font-brand font-bold text-3xl text-anvil dark:text-warm mb-8">What&apos;s inside</h2>
    {app.features && app.features.length > 0 ? (
      <div class="grid md:grid-cols-2 gap-6">
        {app.features.map(f => (
          <div class="p-5 bg-white dark:bg-anvil/40 rounded-xl border border-anvil/10 dark:border-warm/15">
            <h3 class="font-brand font-bold mb-2 text-anvil">{f.name}</h3>
            <p class="text-sm text-anvil/70 dark:text-warm/70 leading-relaxed" set:html={renderInline(f.description)}></p>
          </div>
        ))}
      </div>
    ) : (
      <div class="grid md:grid-cols-3 gap-6">
        <div class="p-5 bg-white dark:bg-anvil/40 rounded-xl border border-anvil/10 dark:border-warm/15">
          <div class="text-3xl mb-2">🎯</div>
          <h3 class="font-brand font-bold mb-2">Learning goal</h3>
          <p class="text-sm text-anvil/70 dark:text-warm/70">{app.tagline}</p>
        </div>
        <div class="p-5 bg-white dark:bg-anvil/40 rounded-xl border border-anvil/10 dark:border-warm/15">
          <div class="text-3xl mb-2">📚</div>
          <h3 class="font-brand font-bold mb-2">Question kits</h3>
          <p class="text-sm text-anvil/70 dark:text-warm/70">
            16 curriculum-aligned kits × 25 questions = 400 questions per app, mapped to recognized standards.
          </p>
        </div>
        <div class="p-5 bg-white dark:bg-anvil/40 rounded-xl border border-anvil/10 dark:border-warm/15">
          <div class="text-3xl mb-2">🤖</div>
          <h3 class="font-brand font-bold mb-2">On-device AI mentor</h3>
          <p class="text-sm text-anvil/70 dark:text-warm/70">
            FoundationModels-powered hints, feedback, and adaptive difficulty — all running locally.
          </p>
        </div>
      </div>
    )}
    {app.mentor && (
      <p class="mt-6 text-sm text-anvil/60 dark:text-warm/60 italic">
        Mentored by <strong class="text-anvil dark:text-warm">{app.mentor}</strong> — on-device AI, no data leaves the device.
      </p>
    )}
  </section>

  <!-- Privacy -->
  <section class="bg-anvil/5 dark:bg-warm/5 py-16">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-brand font-bold text-3xl text-anvil dark:text-warm mb-6">
        How {app.name} handles your kid&apos;s data
      </h2>
      <ul class="space-y-3 text-anvil/80 dark:text-warm/80 leading-relaxed">
        <li>✅ All progress, settings, and AI-generated content stays on the device</li>
        <li>✅ No analytics, no tracking, no third-party SDKs</li>
        <li>✅ No ads, no in-app purchases — you pay once</li>
        <li>✅ COPPA compliant under the 2026 FTC amendments</li>
        <li>✅ Parental controls + session limits + content filters built in</li>
      </ul>
      <p class="mt-6">
        <a href="/for-parents" class="text-forge font-bold hover:underline">Full parent privacy guide →</a>
      </p>
    </div>
  </section>

  <!-- Built with ForgeKit -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <div class="flex items-center gap-4 mb-4">
      <span class="px-3 py-1 bg-forge/10 dark:bg-forge-light/15 text-forge-text dark:text-forge-light text-xs font-bold rounded-full uppercase tracking-wider">
        Built with ForgeKit
      </span>
    </div>
    <p class="text-anvil/80 dark:text-warm/80 leading-relaxed max-w-prose">
      {app.name} runs on ForgeKit — the open-source Swift Package Manager framework that
      powers every Spark &amp; Anvil app. ForgeKit ensures consistent accessibility,
      COPPA compliance, and design language across the portfolio, so your kid&apos;s
      progress and preferences feel coherent across every app they touch.
    </p>
  </section>

  <!-- Coming to App Store CTA -->
  <section class="bg-anvil text-warm py-16">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-brand font-bold text-3xl mb-4">Coming to the App Store</h2>
      <p class="text-warm/80 max-w-prose mx-auto mb-6">
        {app.name} is in active development. Email us to hear when it ships — no marketing,
        no spam, just a one-shot launch announcement.
      </p>
      <a href="mailto:hello@spark-and-anvil.com" class="btn-primary">Email me at launch</a>
    </div>
  </section>
</BaseLayout>
