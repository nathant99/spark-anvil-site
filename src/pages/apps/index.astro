---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AppCard from '~/components/AppCard.astro';
import { site, verticals } from '~/data/site';
import { apps, verticalCounts } from '~/data/apps.generated';
---

<BaseLayout
  title="All Apps"
  description={`Browse all ${site.appCount} Spark & Anvil iOS apps across STEM, STEAM, Academics, DIR/FEDC, and Special Interest verticals.`}
>
  <section class="max-w-6xl mx-auto px-6 pt-16 pb-12">
    <h1 class="font-brand font-bold text-4xl md:text-5xl text-anvil mb-4">
      All apps
    </h1>
    <p class="text-xl text-anvil/70 max-w-2xl mb-6">
      {apps.length} apps currently in active implementation (Waves 1+2+3). {site.appCount - apps.length} more in
      planning. Browse by vertical below.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-12">
    <div class="flex flex-wrap gap-2">
      <button
        class="vertical-filter px-4 py-2 bg-anvil text-warm border border-anvil rounded-full text-sm font-bold"
        data-vertical="all"
      >
        All ({apps.length})
      </button>
      {verticals.map(v => (
        <button
          class="vertical-filter px-4 py-2 bg-white border border-anvil/15 rounded-full text-sm font-medium hover:border-forge hover:text-forge transition-colors"
          data-vertical={v.id}
        >
          {v.name} ({verticalCounts[v.id] ?? 0})
        </button>
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div id="app-grid" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {apps.map(app => (
        <div class="app-card-wrap" data-vertical={app.vertical}>
          <AppCard {...app} />
        </div>
      ))}
    </div>
  </section>

  <section class="bg-anvil/5 py-12">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-anvil/70">
        Wave 4+ apps and the full {site.appCount}-app catalog will populate as their content
        and assets are finalized. Want to be notified when a specific app ships?
        <a href="mailto:hello@spark-and-anvil.com" class="font-bold text-forge hover:underline">Email us</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.vertical-filter');
  const cards = document.querySelectorAll<HTMLDivElement>('.app-card-wrap');

  // Read vertical from URL on load
  const urlVertical = new URLSearchParams(window.location.search).get('vertical') ?? 'all';
  applyFilter(urlVertical);

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const v = btn.dataset.vertical ?? 'all';
      applyFilter(v);
      const u = new URL(window.location.href);
      if (v === 'all') u.searchParams.delete('vertical');
      else u.searchParams.set('vertical', v);
      history.replaceState({}, '', u);
    });
  });

  function applyFilter(v: string) {
    buttons.forEach(b => {
      const active = b.dataset.vertical === v;
      b.classList.toggle('bg-anvil', active);
      b.classList.toggle('text-warm', active);
      b.classList.toggle('border-anvil', active);
      b.classList.toggle('font-bold', active);
      b.classList.toggle('bg-white', !active);
      b.classList.toggle('border-anvil/15', !active);
    });
    cards.forEach(card => {
      const matches = v === 'all' || card.dataset.vertical === v;
      card.style.display = matches ? '' : 'none';
    });
  }
</script>
