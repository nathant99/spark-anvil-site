---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AppCard from '~/components/AppCard.astro';
import { site, verticals } from '~/data/site';
import { apps, verticalCounts } from '~/data/apps.generated';

const implementing = apps.filter(a => a.implementing).length;

const verticalNameById = Object.fromEntries(verticals.map(v => [v.id, v.name]));

// Age band derivation — look for "ages X-Y" pattern in tagline/longTagline;
// default to 9-14 (the tween portfolio anchor). Three exposed buckets:
//   younger  (5-8): max age <= 8
//   tween    (9-14): min age >= 9
//   spanning: bridges both
type AgeBand = 'younger' | 'tween' | 'spanning';
const ageBandFor = (app: typeof apps[number]): AgeBand => {
  const text = `${app.tagline ?? ''} ${(app as any).longTagline ?? ''}`;
  const m = text.match(/[Aa]ges?\s+(\d{1,2})[–\-](\d{1,2})/);
  if (!m) return 'tween';
  const lo = parseInt(m[1], 10);
  const hi = parseInt(m[2], 10);
  if (hi <= 8) return 'younger';
  if (lo >= 9) return 'tween';
  return 'spanning';
};
const ageLabel: Record<AgeBand, string> = {
  younger: 'Ages 5–8',
  tween: 'Ages 9–14',
  spanning: 'Ages 5–14',
};

// Standards bucketing — top 8 buckets covering the long tail.
// Strip the variant suffix so "ISTE 1.5", "ISTE 1.7" both map to "ISTE".
const STANDARD_BUCKETS: Array<{ id: string; label: string; matches: (s: string) => boolean }> = [
  { id: 'iste', label: 'ISTE', matches: (s) => s.startsWith('ISTE') },
  { id: 'ngss', label: 'NGSS', matches: (s) => s.startsWith('NGSS') },
  { id: 'ccss-math', label: 'CCSS Math', matches: (s) => s.startsWith('CCSS Math') },
  { id: 'ccss-ela', label: 'CCSS ELA', matches: (s) => s.startsWith('CCSS ELA') || s.startsWith('CCSS RL') || s.startsWith('CCSS W') },
  { id: 'ncas', label: 'NCAS', matches: (s) => s.startsWith('NCAS') },
  { id: 'c3', label: 'C3 Social Studies', matches: (s) => s.startsWith('C3') },
  { id: 'casel', label: 'CASEL (SEL)', matches: (s) => s.startsWith('CASEL') },
  { id: 'dir-fedc', label: 'DIR/FEDC', matches: (s) => s.startsWith('DIR/FEDC') || s.startsWith('SAMHSA') },
];
const standardsBucketsFor = (app: typeof apps[number]): string[] => {
  const seen = new Set<string>();
  for (const s of app.standards ?? []) {
    for (const b of STANDARD_BUCKETS) {
      if (b.matches(s)) seen.add(b.id);
    }
  }
  return [...seen];
};

// Pre-compute per-app counts for chip labels
const ageCounts: Record<AgeBand, number> = { younger: 0, tween: 0, spanning: 0 };
const standardsCounts: Record<string, number> = {};
const appMeta = apps.map(app => {
  const ageBand = ageBandFor(app);
  const buckets = standardsBucketsFor(app);
  ageCounts[ageBand] += 1;
  for (const b of buckets) standardsCounts[b] = (standardsCounts[b] ?? 0) + 1;
  return { app, ageBand, buckets };
});

// Build a compact, lowercased haystack per card for client-side substring search.
const searchHaystack = (app: typeof apps[number]): string => {
  const parts: string[] = [
    app.name,
    app.tagline ?? '',
    app.mentor ?? '',
    (app.standards ?? []).join(' '),
    verticalNameById[app.vertical] ?? app.vertical,
    app.slug,
  ];
  return parts.join(' ').toLowerCase();
};
---

<BaseLayout
  title="All Apps"
  description={`Browse all ${apps.length} Spark & Anvil iOS apps across STEM, STEAM, Academics, DIR/FEDC, and Special Interest verticals.`}
>
  <section class="max-w-6xl mx-auto px-6 pt-16 pb-8">
    <h1 class="font-brand font-bold text-4xl md:text-5xl text-anvil mb-4">
      All {apps.length} apps
    </h1>
    <p class="text-xl text-anvil/70 max-w-2xl mb-6">
      {implementing} actively in implementation (Waves 1–3); {apps.length - implementing} more in planning.
      Search by name, topic, mentor, or curriculum standard; filter by vertical.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-6">
    <label for="app-search" class="sr-only">Search apps</label>
    <div class="relative">
      <span class="absolute left-4 top-1/2 -translate-y-1/2 text-anvil/40 pointer-events-none" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </span>
      <input
        id="app-search"
        type="search"
        placeholder={`Search ${apps.length} apps by name, topic, mentor, or curriculum...`}
        autocomplete="off"
        class="w-full pl-12 pr-12 py-4 bg-white border-2 border-anvil/15 rounded-full text-base text-anvil placeholder:text-anvil/40 focus:outline-none focus:border-forge transition-colors"
      />
      <button
        id="app-search-clear"
        type="button"
        class="absolute right-4 top-1/2 -translate-y-1/2 text-anvil/40 hover:text-anvil hidden"
        aria-label="Clear search"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <p id="app-search-status" class="text-sm text-anvil/60 mt-2 ml-2" aria-live="polite"></p>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-4">
    <p class="text-xs uppercase tracking-wider text-anvil/50 font-bold mb-2">Vertical</p>
    <div class="flex flex-wrap gap-2">
      <button
        class="vertical-filter px-4 py-2 bg-anvil text-warm border border-anvil rounded-full text-sm font-bold"
        data-vertical="all"
      >
        All ({apps.length})
      </button>
      {verticals.map(v => (
        <button
          class="vertical-filter px-4 py-2 bg-white border border-anvil/15 rounded-full text-sm font-medium hover:border-forge hover:text-forge transition-colors"
          data-vertical={v.id}
        >
          {v.name} ({verticalCounts[v.id] ?? 0})
        </button>
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-4">
    <p class="text-xs uppercase tracking-wider text-anvil/50 font-bold mb-2">Age band</p>
    <div class="flex flex-wrap gap-2">
      <button
        class="age-filter px-4 py-2 bg-anvil text-warm border border-anvil rounded-full text-sm font-bold"
        data-age="all"
      >
        All ages
      </button>
      {(['younger', 'tween', 'spanning'] as const).filter(band => ageCounts[band] > 0).map(band => (
        <button
          class="age-filter px-4 py-2 bg-white border border-anvil/15 rounded-full text-sm font-medium hover:border-forge hover:text-forge transition-colors"
          data-age={band}
        >
          {ageLabel[band]} ({ageCounts[band]})
        </button>
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-12">
    <p class="text-xs uppercase tracking-wider text-anvil/50 font-bold mb-2">Curriculum standard</p>
    <div class="flex flex-wrap gap-2">
      <button
        class="standard-filter px-4 py-2 bg-anvil text-warm border border-anvil rounded-full text-sm font-bold"
        data-standard="all"
      >
        Any standard
      </button>
      {STANDARD_BUCKETS.filter(b => (standardsCounts[b.id] ?? 0) > 0).map(b => (
        <button
          class="standard-filter px-4 py-2 bg-white border border-anvil/15 rounded-full text-sm font-medium hover:border-forge hover:text-forge transition-colors"
          data-standard={b.id}
        >
          {b.label} ({standardsCounts[b.id]})
        </button>
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div id="app-grid" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {appMeta.map(({ app, ageBand, buckets }) => (
        <div
          class="app-card-wrap"
          data-vertical={app.vertical}
          data-implementing={app.implementing ? 'true' : 'false'}
          data-haystack={searchHaystack(app)}
          data-age={ageBand}
          data-standards={buckets.join(',')}
        >
          <AppCard {...app} />
        </div>
      ))}
    </div>
    <div id="app-empty-state" class="hidden text-center py-16">
      <p class="font-brand text-2xl text-anvil/70 mb-2">No apps match that search.</p>
      <p class="text-anvil/60">Try a different keyword, or <button id="app-empty-clear" class="text-forge underline">show all {apps.length} apps</button>.</p>
    </div>
  </section>
</BaseLayout>

<script>
  const verticalButtons = document.querySelectorAll<HTMLButtonElement>('.vertical-filter');
  const ageButtons = document.querySelectorAll<HTMLButtonElement>('.age-filter');
  const standardButtons = document.querySelectorAll<HTMLButtonElement>('.standard-filter');
  const cards = document.querySelectorAll<HTMLDivElement>('.app-card-wrap');
  const searchInput = document.getElementById('app-search') as HTMLInputElement | null;
  const searchClear = document.getElementById('app-search-clear') as HTMLButtonElement | null;
  const searchStatus = document.getElementById('app-search-status') as HTMLParagraphElement | null;
  const emptyState = document.getElementById('app-empty-state') as HTMLDivElement | null;
  const emptyClear = document.getElementById('app-empty-clear') as HTMLButtonElement | null;
  const appGrid = document.getElementById('app-grid') as HTMLDivElement | null;

  const params = new URLSearchParams(window.location.search);
  let currentVertical = params.get('vertical') ?? 'all';
  let currentAge = params.get('age') ?? 'all';
  let currentStandard = params.get('standard') ?? 'all';
  let currentQuery = (params.get('q') ?? '').toLowerCase();
  if (searchInput && currentQuery) searchInput.value = currentQuery;

  applyFilter();

  verticalButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      currentVertical = btn.dataset.vertical ?? 'all';
      syncUrl();
      applyFilter();
    });
  });
  ageButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      currentAge = btn.dataset.age ?? 'all';
      syncUrl();
      applyFilter();
    });
  });
  standardButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      currentStandard = btn.dataset.standard ?? 'all';
      syncUrl();
      applyFilter();
    });
  });

  searchInput?.addEventListener('input', () => {
    currentQuery = (searchInput.value ?? '').trim().toLowerCase();
    syncUrl();
    applyFilter();
  });

  searchClear?.addEventListener('click', () => {
    if (!searchInput) return;
    searchInput.value = '';
    currentQuery = '';
    syncUrl();
    applyFilter();
    searchInput.focus();
  });

  emptyClear?.addEventListener('click', () => {
    currentVertical = 'all';
    currentAge = 'all';
    currentStandard = 'all';
    currentQuery = '';
    if (searchInput) searchInput.value = '';
    syncUrl();
    applyFilter();
  });

  function syncUrl() {
    const u = new URL(window.location.href);
    if (currentVertical === 'all') u.searchParams.delete('vertical');
    else u.searchParams.set('vertical', currentVertical);
    if (currentAge === 'all') u.searchParams.delete('age');
    else u.searchParams.set('age', currentAge);
    if (currentStandard === 'all') u.searchParams.delete('standard');
    else u.searchParams.set('standard', currentStandard);
    if (currentQuery) u.searchParams.set('q', currentQuery);
    else u.searchParams.delete('q');
    history.replaceState({}, '', u);
  }

  function setActive(group: NodeListOf<HTMLButtonElement>, dataAttr: string, current: string) {
    group.forEach(b => {
      const active = b.dataset[dataAttr] === current;
      b.classList.toggle('bg-anvil', active);
      b.classList.toggle('text-warm', active);
      b.classList.toggle('border-anvil', active);
      b.classList.toggle('font-bold', active);
      b.classList.toggle('bg-white', !active);
      b.classList.toggle('border-anvil/15', !active);
    });
  }

  function applyFilter() {
    setActive(verticalButtons, 'vertical', currentVertical);
    setActive(ageButtons, 'age', currentAge);
    setActive(standardButtons, 'standard', currentStandard);

    let visible = 0;
    cards.forEach(card => {
      const verticalMatch = currentVertical === 'all' || card.dataset.vertical === currentVertical;
      const ageMatch = currentAge === 'all' || card.dataset.age === currentAge;
      const cardStandards = (card.dataset.standards ?? '').split(',').filter(Boolean);
      const standardMatch = currentStandard === 'all' || cardStandards.includes(currentStandard);
      const haystack = card.dataset.haystack ?? '';
      const queryMatch = !currentQuery || haystack.includes(currentQuery);
      const matches = verticalMatch && ageMatch && standardMatch && queryMatch;
      card.style.display = matches ? '' : 'none';
      if (matches) visible += 1;
    });

    searchClear?.classList.toggle('hidden', !currentQuery);
    const hasResults = visible > 0;
    emptyState?.classList.toggle('hidden', hasResults);
    appGrid?.classList.toggle('hidden', !hasResults);

    if (searchStatus) {
      const filtersActive = currentQuery || currentVertical !== 'all' || currentAge !== 'all' || currentStandard !== 'all';
      searchStatus.textContent = filtersActive ? `${visible} app${visible === 1 ? '' : 's'} match` : '';
    }
  }
</script>
