---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AppCard from '~/components/AppCard.astro';
import { site, trustSignals, verticals } from '~/data/site';
import { apps, verticalCounts } from '~/data/apps.generated';
import { modes as modeMetas, modeCounts, appsScoringAtLeast, anchorAppsFor } from '~/data/modes';

const mCounts = modeCounts();
// For each mode, the 4 brightest exemplars (score 3, alphabetical) for the home strip
const modeExemplars = Object.fromEntries(
  modeMetas.map(m => [
    m.key,
    appsScoringAtLeast(m.key, 3).slice(0, 4),
  ])
);
// Per-mode anchor apps (Learn → distributed-narrative; Play → adventure modes; Create → multimedia)
const modeAnchorApps = Object.fromEntries(
  modeMetas.map(m => [m.key, anchorAppsFor(m.key)])
);

// Featured apps: prioritize Wave 1+2+3 implementing + most-asset-complete
const featuredSlugs = ['curiosityquest', 'cubesensei', 'quillspell', 'mindforge', 'focusforge', 'bioforge'];
const featured = featuredSlugs
  .map(slug => apps.find(a => a.slug === slug))
  .filter((a): a is NonNullable<typeof a> => Boolean(a));

// Mascot parade: any app with a mascot, dedupe + sample
const mascotApps = apps.filter(a => a.mascotPath).slice(0, 12);

// Distributed-narrative methodology: apps using the character-pattern teaching approach
const dnApps = apps.filter(a => a.distributedNarrative);

// FIX (queue #349 follow-up): the DN section should show CAST PORTRAITS (cast members
// who embody the curriculum), NOT mentor mascots. Pull the first cast member from each
// of the most-canonical DN apps where a portrait actually exists in cast-manifest.json.
import castManifest from '~/data/cast-manifest.json';
const castSet = new Set(castManifest as string[]);

const dnFeaturedCast = ['gambittales', 'proofquest', 'functionforge', 'ratiorealm', 'motiflab']
  .map(slug => {
    const app = apps.find(a => a.slug === slug);
    if (!app?.dnCast?.members?.length) return null;
    const firstMember = app.dnCast.members[0];
    const charSlug = firstMember.name.toLowerCase()
      .replace(/&/g, '-and-')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '') || 'char';
    const key = `${slug}/${charSlug}.webp`;
    return castSet.has(key) ? { app, char: firstMember, portraitPath: `/cast/${key}` } : null;
  })
  .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry));
---

<BaseLayout>
  <!-- Hero — H1-first layout (logo lives in nav) -->
  <section class="max-w-6xl mx-auto px-6 pt-12 md:pt-20 pb-16 md:pb-24">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="text-center md:text-left">
        <span class="inline-block px-3 py-1 mb-4 bg-anvil/10 dark:bg-warm/15 text-anvil dark:text-warm text-xs font-bold uppercase tracking-wider rounded-full">501(c)(3) non-profit (pending)</span>
        <h1 class="font-brand font-bold text-5xl md:text-6xl lg:text-7xl leading-[1.05] text-anvil dark:text-warm mb-6">
          <span class="text-forge">Free forever.</span><br />Educational iOS apps,<br />forged for curiosity.
        </h1>
        <p class="text-lg md:text-xl text-anvil/70 dark:text-warm/70 max-w-xl mb-8 leading-relaxed mx-auto md:mx-0">
          Spark &amp; Anvil's {apps.length} apps for kids ages {site.ages} are <strong>all free, forever</strong>.
          No ads. No in-app purchases. No tracking. On-device AI mentors that never send your kid's data anywhere.
          We're restructuring as a non-profit so it stays that way.
        </p>
        <p class="text-sm text-anvil/60 dark:text-warm/60 max-w-xl mb-8 mx-auto md:mx-0">
          135 apps for tweens <strong>(ages 9–14)</strong> + a Younger Cluster for <strong>ages 5–8</strong> rolling out in 2027.
          Mascot continuity lets kids "graduate" from one portfolio to the next around age 8.
        </p>

        <div class="flex flex-wrap items-center justify-center md:justify-start gap-2 mb-8">
          {trustSignals.map(label => (
            <span class="trust-pill">{label}</span>
          ))}
        </div>

        <div class="flex flex-wrap items-center justify-center md:justify-start gap-4">
          <a href="/apps" class="btn-primary">Browse {apps.length} apps</a>
          <a href="/donate" class="btn-secondary">Support the mission →</a>
        </div>
      </div>

      <!-- Visual side: 6 mascots arranged in an organic cluster -->
      <div class="hidden md:flex justify-center items-center">
        <div class="relative w-full max-w-md aspect-square">
          {mascotApps.slice(0, 6).map((app, i) => {
            const positions = [
              'top-0 left-1/4 w-32 h-32',
              'top-4 right-0 w-28 h-28',
              'top-1/3 left-0 w-24 h-24',
              'bottom-1/4 right-1/4 w-36 h-36',
              'bottom-0 left-1/3 w-28 h-28',
              'top-1/2 right-8 w-24 h-24',
            ];
            return (
              <a
                href={`/apps/${app.slug}`}
                class={`absolute ${positions[i]} rounded-full overflow-hidden border-4 border-warm shadow-lg hover:scale-110 transition-transform`}
                style={`background-color: ${app.heroColor}`}
                aria-label={`${app.name}`}
              >
                <img
                  src={app.mascotPath!}
                  alt={`${app.name} mascot`}
                  class="w-full h-full object-contain"
                  loading="eager"
                />
              </a>
            );
          })}
        </div>
      </div>
    </div>

    <!-- Audience-segmented entry grid (queue #320 Phase 2 + #322 Phase 1) -->
    <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-4 mt-16 max-w-5xl mx-auto">
      {[
        { icon: '👨‍👩‍👧', label: 'For parents',  hook: 'Privacy you can verify. Apps your kid actually uses.',                    href: '/for-parents',  cta: 'For parents →',         stripe: '#4A6FA5', badge: null },
        { icon: '🎓',     label: 'For teachers', hook: 'Earn 100% of class fees. Pilot live classes in 2027.',                  href: '/teach',         cta: 'Apply to the early pilot →',  stripe: '#E8652B', badge: 'Now Recruiting' },
        { icon: '💛',     label: 'Donors',       hook: 'Keep 138 apps free forever. Tax-deductible via fiscal sponsor.',         href: '/donate',        cta: 'Support the mission →', stripe: '#FFBE2E', badge: null },
        { icon: '📰',     label: 'Press',        hook: 'Press kit, brand assets, founder bio.',                                  href: '/press',         cta: 'Press kit →',           stripe: '#2D2D2D', badge: null },
      ].map(tile => (
        <a
          href={tile.href}
          class="group relative block bg-white dark:bg-anvil/40 rounded-2xl p-5 border-2 border-anvil/10 dark:border-warm/15 hover:border-forge transition-colors overflow-hidden"
        >
          <div class="h-1 -mx-5 -mt-5 mb-4" style={`background-color: ${tile.stripe};`} aria-hidden="true"></div>
          {tile.badge && (
            <span class="absolute top-3 right-3 px-2 py-0.5 bg-forge text-warm text-[10px] font-bold uppercase tracking-wider rounded-full">
              {tile.badge}
            </span>
          )}
          <div class="text-3xl mb-2" aria-hidden="true">{tile.icon}</div>
          <h3 class="font-brand font-bold text-lg text-anvil dark:text-warm mb-2">{tile.label}</h3>
          <p class="text-sm text-anvil/70 dark:text-warm/70 leading-snug mb-3">{tile.hook}</p>
          <span class="text-sm font-bold text-forge group-hover:underline">{tile.cta}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Impact ticker (queue #320 Phase 2) -->
  <section class="bg-anvil/5 dark:bg-warm/5 py-12 border-y border-anvil/10 dark:border-warm/15">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-8">
        <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil dark:text-warm">The work, in numbers.</h2>
        <p class="text-sm text-anvil/60 dark:text-warm/60 mt-2">
          Updated 2026-05-23. <a href="/impact" class="underline hover:text-forge">See the full impact report →</a>
        </p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-4">
        {[
          { v: apps.length.toString(),  l: 'iOS apps' },
          { v: '586',                    l: 'cast characters' },
          { v: '21',                     l: 'curriculum frameworks' },
          { v: '80',                     l: 'trauma-informed gates' },
          { v: '0',                      l: 'ads · IAPs · trackers' },
          { v: '100%',                   l: 'free, forever' },
        ].map(s => (
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-brand font-bold text-forge leading-none">{s.v}</div>
            <div class="text-xs uppercase tracking-wider text-anvil/60 dark:text-warm/60 mt-2">{s.l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Learn / Play / Create / Reflect — cross-cutting engagement modes -->
  <section class="py-20 border-y border-anvil/10 dark:border-warm/15">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="text-xs uppercase tracking-wider text-anvil/60 dark:text-warm/60 font-bold mb-3">Four ways your kid engages</p>
        <h2 class="font-brand font-bold text-3xl md:text-4xl text-anvil dark:text-warm mb-4">
          Built around <span style="color: #E8652B;">Learn</span>, <span style="color: #FFBE2E;">Play</span>, <span style="color: #4A6FA5;">Create</span>, and <span style="color: #3D5266;">Reflect</span>
        </h2>
        <p class="text-anvil/70 dark:text-warm/70 max-w-2xl mx-auto leading-relaxed">
          Every app maps to one or more of four engagement modes. Most apps blend two or three — Learn pairs the AI mentor, Play wraps the game shell, Create gives kids something to ship, and Reflect gives them a calm space to think about their own thinking.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {modeMetas.map(m => {
          const exemplars = modeExemplars[m.key] ?? [];
          const anchorApps = modeAnchorApps[m.key] ?? [];
          const total = mCounts[m.key].primary + mCounts[m.key].secondary;
          return (
            <article
              class="rounded-2xl p-6 border-2 bg-white dark:bg-anvil/40 flex flex-col"
              style={`border-color: ${m.hex}66;`}
            >
              <header class="flex items-center gap-3 mb-3">
                <span
                  class="inline-flex items-center justify-center w-12 h-12 rounded-xl text-white font-brand font-bold text-xl shadow-sm"
                  style={`background-color: ${m.hex};`}
                  aria-hidden="true"
                >
                  {m.label[0]}
                </span>
                <div>
                  <h3 class="font-brand font-bold text-2xl text-anvil dark:text-warm leading-tight">{m.label}</h3>
                  <p class="text-xs uppercase tracking-wider text-anvil/50 dark:text-warm/50 font-medium">
                    {total} apps · {mCounts[m.key].primary} primary
                  </p>
                </div>
              </header>
              <p class="text-sm text-anvil/80 dark:text-warm/80 leading-relaxed mb-4">
                {m.blurb}
              </p>

              {/* Concrete portfolio anchor — the named feature that grounds the abstraction */}
              <div
                class="rounded-xl p-4 mb-4 border"
                style={`background-color: ${m.hex}0F; border-color: ${m.hex}33;`}
              >
                <p class="text-xs uppercase tracking-wider font-bold mb-1" style={`color: ${m.hex};`}>
                  Featuring · {anchorApps.length} apps
                </p>
                <p class="font-brand font-bold text-base text-anvil dark:text-warm mb-2">
                  {m.anchor.label}
                </p>
                <p class="text-xs text-anvil/70 dark:text-warm/70 leading-relaxed mb-3">
                  {m.anchor.description}
                </p>
                {anchorApps.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {anchorApps.slice(0, 6).map(app => (
                      <a
                        href={`/apps/${app.slug}`}
                        class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-white dark:bg-anvil/60 border border-anvil/15 dark:border-warm/20 text-xs font-medium text-anvil/80 dark:text-warm/80 hover:opacity-80 transition-opacity"
                        title={app.tagline}
                      >
                        <span
                          class="inline-block w-1.5 h-1.5 rounded-full"
                          style={`background-color: ${app.heroColor};`}
                          aria-hidden="true"
                        ></span>
                        {app.name}
                      </a>
                    ))}
                    {anchorApps.length > 6 && (
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium text-anvil/60 dark:text-warm/60">
                        + {anchorApps.length - 6} more
                      </span>
                    )}
                  </div>
                )}
                <a
                  href={m.anchor.href}
                  class="inline-block mt-3 text-xs font-bold underline hover:no-underline"
                  style={`color: ${m.hex};`}
                >
                  Explore the {m.anchor.label.toLowerCase()} →
                </a>
              </div>

              <a
                href={`/apps?mode=${m.key}`}
                class="inline-block text-sm font-bold transition-opacity hover:opacity-80 mt-auto"
                style={`color: ${m.hex};`}
              >
                See all {m.label} apps →
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Distributed-narrative methodology — our differentiator -->
  <section class="bg-forge/5 dark:bg-forge-light/10 py-20 border-y border-forge/10 dark:border-forge-light/20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="text-xs uppercase tracking-wider text-forge font-bold mb-3">How our apps teach</p>
        <h2 class="font-brand font-bold text-3xl md:text-5xl text-anvil dark:text-warm mb-4 leading-tight">
          Characters who <em class="text-forge not-italic">ARE</em> the curriculum
        </h2>
        <p class="text-lg md:text-xl text-anvil/70 dark:text-warm/70 max-w-2xl mx-auto leading-relaxed">
          Not characters bolted onto worksheets. In <strong>{dnApps.length} of our apps</strong>, every concept your kid needs to learn is embodied by a recurring character — so abstract patterns become memorable through story.
        </p>
      </div>

      {dnFeaturedCast.length > 0 && (
        <div class="flex flex-wrap justify-center items-center gap-4 md:gap-6 mb-12">
          {dnFeaturedCast.map(entry => (
            <a
              href={`/apps/${entry.app.slug}`}
              class="group flex flex-col items-center"
              aria-label={`${entry.char.name} from ${entry.app.name} — embodies the curriculum via distributed-narrative methodology`}
            >
              <div
                class="w-20 h-20 md:w-24 md:h-24 rounded-full flex items-center justify-center overflow-hidden border-4 border-warm shadow-md group-hover:scale-110 transition-transform"
                style={`background-color: ${entry.app.heroColor}`}
              >
                <img
                  src={entry.portraitPath}
                  alt={`${entry.char.name} (cast member of ${entry.app.name})`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
              <span class="mt-2 text-xs font-brand font-bold text-anvil/90 dark:text-warm/90 group-hover:text-forge transition-colors text-center">
                {entry.char.name}
              </span>
              <span class="text-[10px] text-anvil/55 dark:text-warm/55 text-center">
                {entry.app.name}
              </span>
            </a>
          ))}
        </div>
      )}

      <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto mb-10">
        <div class="bg-warm dark:bg-anvil rounded-xl p-6 border border-anvil/10 dark:border-warm/15">
          <h3 class="font-brand font-bold text-base text-forge mb-2">Behavior, not decoration</h3>
          <p class="text-sm text-anvil/70 dark:text-warm/70 leading-relaxed">
            The character's actions <em>are</em> the rule. Sir Pinwell doesn't talk about pins — he does pins. Your kid learns the pattern by watching, not being told.
          </p>
        </div>
        <div class="bg-warm dark:bg-anvil rounded-xl p-6 border border-anvil/10 dark:border-warm/15">
          <h3 class="font-brand font-bold text-base text-forge mb-2">Recurring, not random</h3>
          <p class="text-sm text-anvil/70 dark:text-warm/70 leading-relaxed">
            The same characters appear across many lessons. Familiar faces mean less re-explaining and more time on the actual learning.
          </p>
        </div>
        <div class="bg-warm dark:bg-anvil rounded-xl p-6 border border-anvil/10 dark:border-warm/15">
          <h3 class="font-brand font-bold text-base text-forge mb-2">Small casts, not crowds</h3>
          <p class="text-sm text-anvil/70 dark:text-warm/70 leading-relaxed">
            About 10 to 14 characters per app — never dozens. Kids can keep that many in mind, like a Pixar movie ensemble.
          </p>
        </div>
        <div class="bg-warm dark:bg-anvil rounded-xl p-6 border border-anvil/10 dark:border-warm/15">
          <h3 class="font-brand font-bold text-base text-forge mb-2">Story carries the work</h3>
          <p class="text-sm text-anvil/70 dark:text-warm/70 leading-relaxed">
            When kids care about a character, they remember what that character did. That memory <em>is</em> the curriculum — grounded in Bruner, Sfard, and Habgood's learning research.
          </p>
        </div>
      </div>

      <div class="text-center">
        <a href="/method" class="btn-primary">How distributed-narrative works →</a>
      </div>
    </div>
  </section>

  <!-- Mascot parade -->
  {mascotApps.length > 0 && (
    <section class="bg-anvil/5 dark:bg-warm/5 py-16 overflow-hidden">
      <div class="max-w-6xl mx-auto px-6 mb-8 text-center">
        <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil mb-2 dark:text-warm">
          Meet your mentors
        </h2>
        <p class="text-anvil/70 dark:text-warm/70 max-w-xl mx-auto">
          Every Spark &amp; Anvil app comes with a friendly mentor character that demonstrates, praises, and patiently guides your kid through new skills.
        </p>
      </div>
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
          {mascotApps.map(app => (
            <a
              href={`/apps/${app.slug}`}
              class="group flex flex-col items-center"
            >
              <div
                class="w-24 h-24 md:w-28 md:h-28 rounded-full flex items-center justify-center overflow-hidden border-4 border-warm shadow-md group-hover:scale-110 transition-transform"
                style={`background-color: ${app.heroColor}`}
              >
                <img
                  src={app.mascotPath!}
                  alt={`${app.name} mascot`}
                  class="w-full h-full object-contain"
                  loading="lazy"
                />
              </div>
              <span class="mt-2 text-xs font-brand font-bold text-anvil dark:text-warm text-center group-hover:text-forge transition-colors">
                {app.name}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Why Spark & Anvil -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-brand font-bold text-3xl md:text-4xl text-anvil dark:text-warm mb-12 text-center">
        Why Spark &amp; Anvil
      </h2>
      <div class="grid gap-8 md:grid-cols-3">
        <div>
          <div class="text-5xl mb-3">⚒️</div>
          <h3 class="font-brand font-bold text-xl mb-3">Craft</h3>
          <p class="text-anvil/70 dark:text-warm/70 leading-relaxed">
            Swift 6, SwiftUI, on-device AI via FoundationModels. Native iOS apps that feel like the platform — not web shells, not cross-platform compromises.
          </p>
        </div>
        <div>
          <div class="text-5xl mb-3">🛡️</div>
          <h3 class="font-brand font-bold text-xl mb-3">Safety</h3>
          <p class="text-anvil/70 dark:text-warm/70 leading-relaxed">
            No tracking. No ads. No in-app purchases. No third-party SDKs. All data stays on-device. COPPA compliant under the 2026 FTC amendments.
          </p>
        </div>
        <div>
          <div class="text-5xl mb-3">🌟</div>
          <h3 class="font-brand font-bold text-xl mb-3">Range</h3>
          <p class="text-anvil/70 dark:text-warm/70 leading-relaxed">
            {apps.length} apps across STEM, STEAM, Academics, DIR/FEDC, and Special Interest verticals — for the kid who&apos;s obsessed with rockets AND the one who&apos;s obsessed with sonnets.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured apps -->
  <section class="bg-anvil/5 dark:bg-warm/5 py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-end justify-between mb-10">
        <h2 class="font-brand font-bold text-3xl md:text-4xl text-anvil dark:text-warm">Featured apps</h2>
        <a href="/apps" class="text-forge font-bold text-sm hover:underline">See all {apps.length} →</a>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {featured.map(app => <AppCard {...app} />)}
      </div>
    </div>
  </section>

  <!-- Verticals -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-brand font-bold text-3xl md:text-4xl text-anvil mb-4 text-center dark:text-warm">
        Five learning verticals
      </h2>
      <p class="text-anvil/70 dark:text-warm/70 text-center max-w-2xl mx-auto mb-12">
        Every app maps to one of five learning areas. Browse the portfolio by what interests your kid most.
      </p>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-5">
        {verticals.map(v => (
          <a
            href={`/apps?vertical=${v.id}`}
            class="block p-5 bg-white dark:bg-anvil/40 rounded-xl border border-anvil/10 dark:border-warm/15 hover:border-forge hover:shadow-md transition-all"
          >
            <h3 class="font-brand font-bold text-lg text-forge mb-2">
              {v.name} <span class="text-anvil/50 dark:text-warm/50 text-sm font-normal">({verticalCounts[v.id]})</span>
            </h3>
            <p class="text-sm text-anvil/70 dark:text-warm/70 leading-relaxed">{v.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Parent CTA -->
  <section class="bg-anvil/5 dark:bg-warm/5 py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-brand font-bold text-3xl md:text-4xl text-anvil dark:text-warm mb-4">
        Apps your kid can actually use.<br />Privacy you can actually verify.
      </h2>
      <p class="text-lg text-anvil/70 dark:text-warm/70 mb-8 max-w-2xl mx-auto">
        Read our full privacy commitment and the parent-friendly summary of how we handle data.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/for-parents" class="btn-primary">For parents</a>
        <a href="/for-educators" class="btn-secondary">For educators</a>
      </div>
    </div>
  </section>
</BaseLayout>
