---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { apps } from '~/data/apps.generated';
import { verticals } from '~/data/site';

// Apps that ship pass-and-play / face-to-face modes today
const liveApps = apps.filter(a => a.playTogether === true);
const liveCount = liveApps.length;
const byVerticalLive = verticals.map(v => ({
  ...v,
  apps: liveApps.filter(a => a.vertical === v.id),
})).filter(v => v.apps.length > 0);

// Ceiling per research §4: ~111 apps (~80%) are good-fit candidates
const ceiling = 111;
const totalApps = apps.length;
---

<BaseLayout
  title="Play Together"
  description={`Designed for face-to-face play. ${liveCount} of our ${totalApps} apps ship pass-and-play modes so you can hand the device back and forth with your kid, sibling, or grandparent.`}
>
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-12">
    <div class="flex items-start gap-6 flex-wrap">
      <div class="flex-1 min-w-[280px]">
        <span class="inline-block px-3 py-1 mb-4 bg-forge text-warm text-xs font-bold uppercase tracking-wider rounded-full">Face-to-face mode</span>
        <h1 class="font-brand font-bold text-4xl md:text-5xl text-anvil dark:text-warm mb-4">
          Play together.
          <span class="block text-forge">Pass the device.</span>
        </h1>
        <p class="text-xl text-anvil/70 dark:text-warm/70 max-w-2xl leading-relaxed">
          Some of our apps are designed for two-or-more humans on one device. Take turns. Pass the
          device between rounds. Sit on the couch with your kid, sibling, or grandparent. Build
          vocabulary, beat the puzzle, share the moment.
        </p>
        <p class="mt-4 text-anvil/60 dark:text-warm/60 leading-relaxed max-w-2xl">
          The research is clear: face-to-face play — even device-mediated — builds family cohesion,
          co-regulation, and shared meaning in ways solo-play can't. <a href="/for-parents" class="underline hover:text-forge">More for parents →</a>
        </p>
      </div>
      <img
        src="/brand/logomark-cartoon.webp"
        alt="Spark & Anvil cartoon mark"
        class="w-32 h-32 md:w-40 md:h-40 flex-shrink-0"
        loading="eager"
      />
    </div>
  </section>

  <!-- Stats strip -->
  <section class="max-w-4xl mx-auto px-6 pb-12">
    <div class="flex flex-wrap gap-6 text-sm">
      <span class="text-anvil/70 dark:text-warm/70">
        <strong class="text-anvil dark:text-warm text-2xl font-brand block">{liveCount}</strong>
        apps with pass-and-play <span class="text-xs">today</span>
      </span>
      <span class="text-anvil/70 dark:text-warm/70">
        <strong class="text-anvil dark:text-warm text-2xl font-brand block">~{ceiling}</strong>
        more <span class="text-xs">on the roadmap</span>
      </span>
      <span class="text-anvil/70 dark:text-warm/70">
        <strong class="text-anvil dark:text-warm text-2xl font-brand block">1</strong>
        device per game <span class="text-xs">(no extra hardware)</span>
      </span>
      <span class="text-anvil/70 dark:text-warm/70">
        <strong class="text-anvil dark:text-warm text-2xl font-brand block">2-6</strong>
        players per session
      </span>
    </div>
  </section>

  <!-- Live apps -->
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil dark:text-warm mb-2">
        Available today
      </h2>
      <p class="text-anvil/60 dark:text-warm/60 mb-8">
        {liveCount} apps ship at least one pass-and-play / hot-seat / cooperative mode designed
        for two or more humans on one device.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {liveApps.map(app => (
          <article class="bg-white dark:bg-anvil/40 rounded-2xl p-5 border-2 border-anvil/10 dark:border-warm/10 hover:border-forge/40 transition-colors">
            <header class="flex items-center gap-3 mb-3">
              {app.mascotPath ? (
                <div
                  class="w-12 h-12 rounded-xl overflow-hidden border-2 border-warm flex-shrink-0"
                  style={`background-color: ${app.heroColor}`}
                >
                  <img
                    src={app.mascotPath}
                    alt=""
                    class="w-full h-full object-contain"
                    loading="lazy"
                  />
                </div>
              ) : (
                <div
                  class="w-12 h-12 rounded-xl flex-shrink-0 flex items-center justify-center font-brand font-bold text-white text-xl"
                  style={`background-color: ${app.heroColor}`}
                >
                  {app.name.charAt(0)}
                </div>
              )}
              <div class="min-w-0 flex-1">
                <a href={`/apps/${app.slug}`} class="block font-brand font-bold text-anvil dark:text-warm hover:text-forge transition-colors truncate">
                  {app.name}
                </a>
                <p class="text-xs text-anvil/60 dark:text-warm/60 truncate">
                  {app.vertical.toUpperCase()}
                </p>
              </div>
            </header>
            <p class="text-sm text-anvil/70 dark:text-warm/70 leading-snug line-clamp-3">
              {app.tagline}
            </p>
            <div class="mt-3 inline-flex items-center gap-1 px-2 py-0.5 bg-forge/10 dark:bg-forge/20 rounded text-xs font-medium text-forge">
              <span>👥</span>
              <span>Pass-and-play available</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Why this matters -->
  <section class="bg-anvil/5 dark:bg-warm/5 py-16">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil dark:text-warm mb-6">
        Why pass-and-play matters
      </h2>
      <div class="space-y-4 text-anvil/80 dark:text-warm/80 leading-relaxed">
        <p>
          Modern educational apps default to solo play. A kid sits alone with the device. Even
          when apps add multiplayer, it's usually networked — two devices, two rooms.
        </p>
        <p>
          Pass-and-play is different. It collapses the device-as-isolator into a shared object.
          You're on the couch. You hand the device back and forth. You watch your kid think.
          They watch you think. You laugh together. You argue. You restart the round.
        </p>
        <p>
          The SEL and family-cohesion research — Riley & Gaspar's <em>Connected by Play</em>,
          CASEL's family-engagement framework, the 2024 Common Sense data on device-mediated
          face-time — all point the same direction: <strong>kids learn faster, and feel safer,
          when an adult is co-present in the play moment</strong>.
        </p>
        <p>
          Our apps that ship pass-and-play modes use Apple's MultipeerConnectivity and our own
          ForgePassAndPlay framework to make the handoff feel natural: privacy curtain between
          turns, no peeking at hidden hands, gentle round-end cues, no leaderboards that
          embarrass anyone.
        </p>
      </div>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil dark:text-warm mb-4">
      On the roadmap
    </h2>
    <p class="text-anvil/70 dark:text-warm/70 mb-6 leading-relaxed">
      ~{ceiling} of our {totalApps} apps are good fits for pass-and-play modes — sentence games,
      role-play scenes, cooperative rounds, family co-regulation pairs. We're retrofitting wave
      by wave. The next four pilots already have implementation handoffs in flight:
    </p>
    <ul class="space-y-3 text-anvil/80 dark:text-warm/80">
      <li class="flex gap-3">
        <span class="font-brand font-bold text-forge flex-shrink-0 w-32">MindForge</span>
        <span class="text-sm leading-snug">Co-regulation breath pair — parent + child pace breathing together; highest evidence base in the SEL literature.</span>
      </li>
      <li class="flex gap-3">
        <span class="font-brand font-bold text-forge flex-shrink-0 w-32">GrammarForge</span>
        <span class="text-sm leading-snug">Sentence Hot Potato — one player starts a sentence, passes the device, the next adds a word, and so on.</span>
      </li>
      <li class="flex gap-3">
        <span class="font-brand font-bold text-forge flex-shrink-0 w-32">SafetyForge</span>
        <span class="text-sm leading-snug">Bystander role-play — kid + parent take alternating roles in a digital-citizenship scenario.</span>
      </li>
      <li class="flex gap-3">
        <span class="font-brand font-bold text-forge flex-shrink-0 w-32">CardForge</span>
        <span class="text-sm leading-snug">Family cooperative round — everyone plays for the same score; the deck and the game design do the work.</span>
      </li>
    </ul>
  </section>

  <!-- CTA -->
  <section class="bg-anvil text-warm py-16">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-brand font-bold text-3xl mb-4">Make it a family thing</h2>
      <p class="text-warm/80 leading-relaxed max-w-prose mx-auto mb-6">
        We design pass-and-play modes for the couch, the dinner table, the long car ride,
        the rainy Saturday afternoon. One device. Two or more humans. No subscription. No ads.
        Just the round, and the laugh, and the moment of shared attention.
      </p>
      <a href="/apps?mode=play-together" class="btn-primary">Browse pass-and-play apps →</a>
    </div>
  </section>
</BaseLayout>
