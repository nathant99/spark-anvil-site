---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { apps } from '~/data/apps.generated';
import { verticals } from '~/data/site';

// Together-pillar members: apps with modes.together >= 2 (PRIMARY or SECONDARY).
// Per `labsmith/Docs/RESEARCH_TOGETHER_5TH_PILLAR.md` (Round 78 #397).
const pillarApps = apps.filter(a => a.modes?.together && a.modes.together >= 2);
const primaryApps = apps.filter(a => a.modes?.together === 3);
const secondaryApps = apps.filter(a => a.modes?.together === 2);

// Apps that ship pass-and-play / face-to-face modes TODAY (sidecar boolean).
// Subset of pillarApps; surfaced as "shipping today" indicator.
const liveApps = apps.filter(a => a.playTogether === true);
const liveSlugSet = new Set(liveApps.map(a => a.slug));
const liveCount = liveApps.length;
const pillarCount = pillarApps.length;
const primaryCount = primaryApps.length;
const secondaryCount = secondaryApps.length;

// Ceiling per research §4: ~111 apps (~80%) are good-fit candidates
const ceiling = 111;
const totalApps = apps.length;
---

<BaseLayout
  title="Together"
  description={`Together is the 5th Spark & Anvil pillar — apps designed for face-to-face play. ${primaryCount} apps where partnership IS the curriculum, ${secondaryCount} with strong Together-mode surfaces, and ${liveCount} shipping pass-and-play today.`}
>
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-12">
    <div class="flex items-start gap-6 flex-wrap">
      <div class="flex-1 min-w-[280px]">
        <span class="inline-block px-3 py-1 mb-4 bg-sage text-warm text-xs font-bold uppercase tracking-wider rounded-full">5th pillar · Together</span>
        <h1 class="font-brand font-bold text-4xl md:text-5xl text-anvil dark:text-warm mb-4">
          Play side-by-side.
          <span class="block text-sage">Pass the device.</span>
        </h1>
        <p class="text-xl text-anvil/70 dark:text-warm/70 max-w-2xl leading-relaxed">
          Together is the engagement modality where two-or-more humans share one device. Pass-and-play modes, family-cooperative rounds, dyadic co-regulation pairs, aggregator hubs. Couch-coop, dinner table, classroom group, rainy Saturday afternoon.
        </p>
        <p class="mt-4 text-anvil/60 dark:text-warm/60 leading-relaxed max-w-2xl">
          The research is clear — Vygotsky's zone of proximal development, Tronick's dyadic co-regulation, Hirsh-Pasek's Social Interaction pillar, and Johnson &amp; Johnson's cooperative-learning meta-analyses (d ≈ 0.42-0.47 on K-12 academic outcomes) all converge on co-located play as a productive learning context. <a href="/for-parents" class="underline hover:text-sage">More for parents →</a>
        </p>
      </div>
      <img
        src="/brand/logomark-cartoon.webp"
        alt="Spark & Anvil cartoon mark"
        class="w-32 h-32 md:w-40 md:h-40 flex-shrink-0"
        loading="eager"
      />
    </div>
  </section>

  <!-- Stats strip -->
  <section class="max-w-4xl mx-auto px-6 pb-12">
    <div class="flex flex-wrap gap-6 text-sm">
      <span class="text-anvil/70 dark:text-warm/70">
        <strong class="text-anvil dark:text-warm text-2xl font-brand block">{primaryCount}</strong>
        Together-<strong class="text-sage">primary</strong> <span class="text-xs">apps</span>
      </span>
      <span class="text-anvil/70 dark:text-warm/70">
        <strong class="text-anvil dark:text-warm text-2xl font-brand block">{secondaryCount}</strong>
        Together-secondary <span class="text-xs">apps</span>
      </span>
      <span class="text-anvil/70 dark:text-warm/70">
        <strong class="text-anvil dark:text-warm text-2xl font-brand block">{liveCount}</strong>
        shipping pass-and-play <span class="text-xs">today</span>
      </span>
      <span class="text-anvil/70 dark:text-warm/70">
        <strong class="text-anvil dark:text-warm text-2xl font-brand block">~{ceiling}</strong>
        ceiling <span class="text-xs">(~80% of portfolio)</span>
      </span>
      <span class="text-anvil/70 dark:text-warm/70">
        <strong class="text-anvil dark:text-warm text-2xl font-brand block">1</strong>
        device per game <span class="text-xs">(no extra hardware)</span>
      </span>
    </div>
  </section>

  <!-- Pillar members -->
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil dark:text-warm mb-2">
        Together-pillar apps
      </h2>
      <p class="text-anvil/60 dark:text-warm/60 mb-8">
        {pillarCount} apps where co-located play is part of the proposition — {primaryCount} where partnership IS the curriculum (the gameplay only works with two-or-more humans together) plus {secondaryCount} with strong Together-mode surfaces alongside their primary modality. The {liveCount} with the "Shipping today" badge ship pass-and-play modes right now.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {pillarApps.map(app => {
          const isLive = liveSlugSet.has(app.slug);
          const isPrimary = app.modes?.together === 3;
          return (
            <article class="bg-white dark:bg-anvil/40 rounded-2xl p-5 border-2 border-anvil/10 dark:border-warm/10 hover:border-sage/40 transition-colors">
              <header class="flex items-center gap-3 mb-3">
                {app.mascotPath ? (
                  <div
                    class="w-12 h-12 rounded-xl overflow-hidden border-2 border-warm flex-shrink-0"
                    style={`background-color: ${app.heroColor}`}
                  >
                    <img
                      src={app.mascotPath}
                      alt=""
                      class="w-full h-full object-contain"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div
                    class="w-12 h-12 rounded-xl flex-shrink-0 flex items-center justify-center font-brand font-bold text-white text-xl"
                    style={`background-color: ${app.heroColor}`}
                  >
                    {app.name.charAt(0)}
                  </div>
                )}
                <div class="min-w-0 flex-1">
                  <a href={`/apps/${app.slug}`} class="block font-brand font-bold text-anvil dark:text-warm hover:text-sage transition-colors truncate">
                    {app.name}
                  </a>
                  <p class="text-xs text-anvil/60 dark:text-warm/60 truncate">
                    {app.vertical.toUpperCase()}
                  </p>
                </div>
              </header>
              <p class="text-sm text-anvil/70 dark:text-warm/70 leading-snug line-clamp-3">
                {app.tagline}
              </p>
              <div class="mt-3 flex flex-wrap gap-2">
                <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium ${isPrimary ? 'bg-sage/15 text-sage-text dark:text-sage-light' : 'bg-sage/10 text-sage-text dark:text-sage-light'}`}>
                  <span>{isPrimary ? '⭐' : '👥'}</span>
                  <span>{isPrimary ? 'Together-primary' : 'Together-secondary'}</span>
                </span>
                {isLive && (
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-forge/10 dark:bg-forge/20 rounded text-xs font-medium text-forge">
                    <span>✓</span>
                    <span>Shipping today</span>
                  </span>
                )}
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Why this matters -->
  <section class="bg-anvil/5 dark:bg-warm/5 py-16">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil dark:text-warm mb-6">
        Why the Together pillar matters
      </h2>
      <div class="space-y-4 text-anvil/80 dark:text-warm/80 leading-relaxed">
        <p>
          Modern educational apps default to solo play. A kid sits alone with the device. Even
          when apps add multiplayer, it's usually networked — two devices, two rooms.
        </p>
        <p>
          Together is different. It collapses the device-as-isolator into a shared object.
          You're on the couch. You hand the device back and forth. You watch your kid think.
          They watch you think. You laugh together. You argue. You restart the round.
        </p>
        <p>
          The learning science converges on co-located play as a productive context:
        </p>
        <ul class="list-disc pl-6 space-y-2 text-anvil/80 dark:text-warm/80">
          <li><strong>Vygotsky's zone of proximal development</strong> — the child's emerging abilities are activated specifically through the More Knowledgeable Other (parent, sibling, peer) in co-play settings.</li>
          <li><strong>Tronick's still-face research</strong> — 70% of caregiver-infant interactions are mismatched; <em>repair</em> through dyadic co-regulation is "the key developmental force."</li>
          <li><strong>Hirsh-Pasek's 4 Pillars of Learning</strong> — Social Interaction is one of the four canonical pillars of educational-app quality.</li>
          <li><strong>Johnson &amp; Johnson / Slavin cooperative-learning meta-analyses</strong> — cooperative-learning interventions show d ≈ 0.42-0.47 on K-12 academic outcomes; Learning Together (LT) produces the strongest effect across methods.</li>
          <li><strong>K-State 2024 family-cohesion research</strong> — families with weekly co-play show 30% higher cohesion scores and 25% less reported loneliness after six months.</li>
          <li><strong>AAP 2026 screen-time guidance</strong> — pivoted from hour-based limits to quality-over-time, with co-viewing-with-active-participation explicitly named as a quality marker for ages 2-5+.</li>
        </ul>
        <p>
          Our Together-pillar apps use Apple's MultipeerConnectivity and our own ForgePassAndPlay
          framework to make the handoff feel natural: privacy curtain between turns, no peeking at
          hidden hands, gentle round-end cues, no leaderboards that embarrass anyone.
        </p>
      </div>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil dark:text-warm mb-4">
      On the roadmap
    </h2>
    <p class="text-anvil/70 dark:text-warm/70 mb-6 leading-relaxed">
      ~{ceiling} of our {totalApps} apps are good fits for pass-and-play modes — sentence games,
      role-play scenes, cooperative rounds, family co-regulation pairs. We're retrofitting wave
      by wave. The next four pilots already have implementation handoffs in flight:
    </p>
    <ul class="space-y-3 text-anvil/80 dark:text-warm/80">
      <li class="flex gap-3">
        <span class="font-brand font-bold text-forge flex-shrink-0 w-32">MindForge</span>
        <span class="text-sm leading-snug">Co-regulation breath pair — parent + child pace breathing together; highest evidence base in the SEL literature.</span>
      </li>
      <li class="flex gap-3">
        <span class="font-brand font-bold text-forge flex-shrink-0 w-32">GrammarForge</span>
        <span class="text-sm leading-snug">Sentence Hot Potato — one player starts a sentence, passes the device, the next adds a word, and so on.</span>
      </li>
      <li class="flex gap-3">
        <span class="font-brand font-bold text-forge flex-shrink-0 w-32">SafetyForge</span>
        <span class="text-sm leading-snug">Bystander role-play — kid + parent take alternating roles in a digital-citizenship scenario.</span>
      </li>
      <li class="flex gap-3">
        <span class="font-brand font-bold text-forge flex-shrink-0 w-32">CardForge</span>
        <span class="text-sm leading-snug">Family cooperative round — everyone plays for the same score; the deck and the game design do the work.</span>
      </li>
    </ul>
  </section>

  <!-- CTA -->
  <section class="bg-anvil text-warm py-16">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-brand font-bold text-3xl mb-4">Make it a family thing</h2>
      <p class="text-warm/80 leading-relaxed max-w-prose mx-auto mb-6">
        We design pass-and-play modes for the couch, the dinner table, the long car ride,
        the rainy Saturday afternoon. One device. Two or more humans. No subscription. No ads.
        Just the round, and the laugh, and the moment of shared attention.
      </p>
      <a href="/apps?mode=play-together" class="btn-primary">Browse pass-and-play apps →</a>
    </div>
  </section>
</BaseLayout>
