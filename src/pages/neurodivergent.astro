---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { apps } from '~/data/apps.generated';
import { verticals } from '~/data/site';

// Apps flagged with documented neurodivergent-supportive design.
const ndApps = apps.filter(a => a.neurodivergentSupport === true);
const ndCount = ndApps.length;
const totalApps = apps.length;

// Stats — count distinct traits + total evidence entries.
const traitSet = new Set<string>();
let evidenceCount = 0;
for (const app of ndApps) {
  (app.neurodivergentDesignTraits ?? []).forEach(t => traitSet.add(t));
  evidenceCount += (app.neurodivergentEvidence ?? []).length;
}
const traitCount = traitSet.size;

// Filter chips — 6 umbrella categories per PLAN §3.4. Each chip maps to
// a set of trait pills via includes-match (case-insensitive prefix).
const filterChips = [
  { id: 'sensory-aware', label: 'Sensory-Aware', match: ['Sensory-aware', 'Low-stimulus'] },
  { id: 'focus-supportive', label: 'Focus-Supportive', match: ['Focus-supportive', 'ADHD-supportive'] },
  { id: 'sel', label: 'SEL', match: ['Trauma-informed', 'Strength-based'] },
  { id: 'communication', label: 'Communication-Scaffolding', match: ['Communication-scaffolding'] },
  { id: 'identity', label: 'Identity-Affirming', match: ['Identity-affirming'] },
  { id: 'co-regulation', label: 'Co-Regulation', match: ['Co-regulation', 'Interoception'] },
];

// For each app, compute the set of filter-chip IDs it satisfies for client-side filtering.
function chipsFor(traits: string[] | undefined): string[] {
  if (!traits) return [];
  const hits = new Set<string>();
  for (const chip of filterChips) {
    for (const t of traits) {
      if (chip.match.some(m => t.toLowerCase().includes(m.toLowerCase()))) {
        hits.add(chip.id);
        break;
      }
    }
  }
  return Array.from(hits);
}
---

<BaseLayout
  title="Neurodivergent Support"
  description={`Made with neurodivergent kids in mind. ${ndCount} of our ${totalApps} apps ship documented neurodivergent-supportive design — sensory overrides, focus scaffolds, predictable flows, identity-first language, co-regulation patterns, and trauma-informed gates.`}
>
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-8">
    <div class="flex items-start gap-6 flex-wrap">
      <div class="flex-1 min-w-[280px]">
        <span class="inline-block px-3 py-1 mb-4 bg-forge text-warm text-xs font-bold uppercase tracking-wider rounded-full">Neurodivergent support</span>
        <h1 class="font-brand font-bold text-4xl md:text-5xl text-anvil dark:text-warm mb-4">
          Made with neurodivergent kids
          <span class="block text-forge">in mind.</span>
        </h1>
        <p class="text-xl text-anvil/70 dark:text-warm/70 max-w-2xl leading-relaxed">
          Autistic, ADHD, dyslexic, dyspraxic, dyscalculic, OCD, Tourette's, and twice-exceptional
          kids deserve apps built around how their brains actually work — not workarounds for
          what a "typical" kid would do.
        </p>
        <p class="mt-4 text-anvil/60 dark:text-warm/60 leading-relaxed max-w-2xl">
          Across our portfolio, {ndCount} apps ship documented neurodivergent-supportive design —
          sensory overrides, focus scaffolds, predictable flows, identity-first language,
          co-regulation patterns, and trauma-informed gates. The full list, with the evidence
          base for each, is below.
        </p>
      </div>
      <img
        src="/brand/logomark-cartoon.webp"
        alt=""
        class="w-32 h-32 md:w-40 md:h-40 flex-shrink-0"
        loading="eager"
      />
    </div>
  </section>

  <!-- Parent disclaimer -->
  <section class="max-w-4xl mx-auto px-6 pb-10">
    <aside class="border-2 border-anvil/20 dark:border-warm/20 rounded-xl p-4 bg-warm/40 dark:bg-anvil/40">
      <p class="text-sm text-anvil/80 dark:text-warm/80 leading-relaxed">
        <strong>Not medical advice.</strong> This is a curated discovery surface — not a diagnostic
        tool, not a treatment, not a substitute for clinical care, IEPs, 504s, or therapy. The apps
        below are general-population educational tools that incorporate neurodivergent-supportive
        design. If you or your kid are in crisis, the
        <a href="#crisis-resources" class="underline hover:text-forge">resources at the bottom of this page</a>
        can help right now.
      </p>
    </aside>
  </section>

  <!-- Stats strip -->
  <section class="max-w-4xl mx-auto px-6 pb-12">
    <div class="flex flex-wrap gap-6 text-sm">
      <span class="text-anvil/70 dark:text-warm/70">
        <strong class="text-anvil dark:text-warm text-2xl font-brand block">{ndCount}</strong>
        apps with documented ND-supportive design
      </span>
      <span class="text-anvil/70 dark:text-warm/70">
        <strong class="text-anvil dark:text-warm text-2xl font-brand block">{traitCount}</strong>
        design traits across the catalog
      </span>
      <span class="text-anvil/70 dark:text-warm/70">
        <strong class="text-anvil dark:text-warm text-2xl font-brand block">{evidenceCount}</strong>
        per-app evidence-base entries
      </span>
      <span class="text-anvil/70 dark:text-warm/70">
        <strong class="text-anvil dark:text-warm text-2xl font-brand block">100%</strong>
        free · on-device · no tracking
      </span>
    </div>
  </section>

  <!-- Filter chips -->
  <section class="max-w-6xl mx-auto px-6 pb-6" aria-label="Filter apps by design property">
    <p class="text-sm text-anvil/60 dark:text-warm/60 mb-3">Filter by design property:</p>
    <div class="flex flex-wrap gap-2" id="nd-filter-chips" role="group">
      <button
        type="button"
        data-chip="all"
        class="nd-chip nd-chip-active"
        aria-pressed="true"
      >
        All apps ({ndCount})
      </button>
      {filterChips.map(chip => (
        <button type="button" data-chip={chip.id} class="nd-chip" aria-pressed="false">
          {chip.label}
        </button>
      ))}
    </div>
  </section>

  <!-- App cards -->
  <section class="py-8">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil dark:text-warm mb-2">
        Apps designed for neurodivergent learners
      </h2>
      <p class="text-anvil/60 dark:text-warm/60 mb-8">
        {ndCount} apps with cast-design + sensitivity-reviewer + framework-citation documentation.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="nd-app-grid">
        {ndApps.map(app => {
          const traits = app.neurodivergentDesignTraits ?? [];
          const evidence = app.neurodivergentEvidence ?? [];
          const chipIds = chipsFor(traits).join(' ');
          return (
            <article
              class="nd-card bg-white dark:bg-anvil/40 rounded-2xl p-5 border-2 border-anvil/10 dark:border-warm/10 hover:border-forge/40 transition-colors flex flex-col"
              data-chips={chipIds}
            >
              <header class="flex items-center gap-3 mb-3">
                {app.mascotPath ? (
                  <div
                    class="w-12 h-12 rounded-xl overflow-hidden border-2 border-warm flex-shrink-0"
                    style={`background-color: ${app.heroColor}`}
                  >
                    <img
                      src={app.mascotPath}
                      alt=""
                      class="w-full h-full object-contain"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div
                    class="w-12 h-12 rounded-xl flex-shrink-0 flex items-center justify-center font-brand font-bold text-white text-xl"
                    style={`background-color: ${app.heroColor}`}
                  >
                    {app.name.charAt(0)}
                  </div>
                )}
                <div class="min-w-0 flex-1">
                  <a href={`/apps/${app.slug}`} class="block font-brand font-bold text-anvil dark:text-warm hover:text-forge transition-colors truncate">
                    {app.name}
                  </a>
                  <p class="text-xs text-anvil/60 dark:text-warm/60 truncate">
                    {app.vertical.toUpperCase()}
                  </p>
                </div>
              </header>
              <p class="text-sm text-anvil/70 dark:text-warm/70 leading-snug line-clamp-3 mb-3">
                {app.tagline}
              </p>
              <div class="flex flex-wrap gap-1 mb-3">
                {traits.map(t => (
                  <span class="inline-block px-2 py-0.5 bg-anvil/5 dark:bg-warm/10 text-anvil/80 dark:text-warm/80 rounded text-[11px] font-medium">
                    {t}
                  </span>
                ))}
              </div>
              {evidence.length > 0 && (
                <details class="mt-auto group">
                  <summary class="cursor-pointer text-xs font-medium text-anvil/60 dark:text-warm/60 hover:text-forge transition-colors select-none">
                    Evidence base ({evidence.length}) <span class="group-open:hidden">▸</span><span class="hidden group-open:inline">▾</span>
                  </summary>
                  <ul class="mt-2 space-y-2 text-xs text-anvil/70 dark:text-warm/70">
                    {evidence.slice(0, 2).map(e => (
                      <li>
                        <strong class="block text-anvil dark:text-warm">{e.aspect}</strong>
                        <span class="text-anvil/60 dark:text-warm/60">{e.basis}</span>
                      </li>
                    ))}
                    {evidence.length > 2 && (
                      <li class="text-anvil/50 dark:text-warm/50 italic">
                        + {evidence.length - 2} more — see <a href={`/apps/${app.slug}`} class="underline hover:text-forge">app page</a>
                      </li>
                    )}
                  </ul>
                </details>
              )}
              <div class="mt-3 inline-flex items-center gap-1 px-2 py-0.5 bg-forge/10 dark:bg-forge/20 rounded text-xs font-medium text-forge self-start">
                <span>🧠</span>
                <span>Designed for neurodivergent learners</span>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- What is "neurodivergent"? Educator-friendly explainer -->
  <section class="bg-anvil/5 dark:bg-warm/5 py-16">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil dark:text-warm mb-6">
        What does "neurodivergent" mean?
      </h2>
      <div class="space-y-4 text-anvil/80 dark:text-warm/80 leading-relaxed">
        <p>
          <strong>Neurodivergent</strong> is an umbrella term for people whose brain wiring differs
          from what's typical — autistic, ADHD, dyslexic, dyspraxic, dyscalculic, OCD, Tourette's,
          twice-exceptional (2e), and others. The term was coined by Kassiane Asasumasu and
          popularized by Nick Walker (2021); it's the current advocacy-community consensus for the
          umbrella category.
        </p>
        <p>
          <strong>Neurotypical</strong> describes people whose brain wiring matches the statistical
          majority. It's a descriptive category, not a value judgment.
        </p>
        <p>
          <strong>Neurodiversity</strong> is the broader paradigm — the recognition that brain
          variation is natural human variation (Singer 1998; den Houting 2019; Dwyer 2022). Like
          biodiversity, neurodiversity is a property of populations, not individuals.
        </p>
        <p class="text-sm bg-warm/40 dark:bg-anvil/40 rounded-lg p-4 border border-anvil/10 dark:border-warm/10">
          <strong>A note on language.</strong> Throughout this page we use identity-first language
          ("autistic kid", "ADHD learner", "dyslexic kid") rather than person-first language ("kid
          with autism"). This is the current preference of the majority of autistic, ADHD, and
          dyslexic adults per Botha 2022 / Bury 2020 / Kenny 2016 and per ASAN, CHADD, LDA, and
          Decoding Dyslexia consensus. Some individuals prefer person-first; we respect both — the
          page default is identity-first.
        </p>
        <p class="text-sm text-anvil/60 dark:text-warm/60">
          For more depth, see
          <a href="https://www.nami.org/" class="underline hover:text-forge" rel="noopener">NAMI</a>,
          <a href="https://autismsociety.org/" class="underline hover:text-forge" rel="noopener">Autism Society</a>,
          <a href="https://chadd.org/" class="underline hover:text-forge" rel="noopener">CHADD</a>, or
          <a href="https://www.decodingdyslexia.net/" class="underline hover:text-forge" rel="noopener">Decoding Dyslexia</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Evidence-base disclosure -->
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h2 class="font-brand font-bold text-2xl md:text-3xl text-anvil dark:text-warm mb-6">
      Our editorial standard
    </h2>
    <div class="space-y-4 text-anvil/80 dark:text-warm/80 leading-relaxed">
      <p>
        Every ND-support claim on this page is sourced. Each app's evidence-base entries come from
        the app's cast-design handoff, an engaged sensitivity reviewer, or a cited framework — not
        marketing copy.
      </p>
      <p>
        External sensitivity reviewers are engaged for our most sensitivity-gated apps: a
        CHADD-affiliated reviewer for FocusForge; a DIR-Floortime-certified reviewer for
        CoRegRealm; a CASEL-affiliated + pediatric-mental-health-clinician reviewer (required, not
        optional) for MindForge; and others. Cumulative reviewer envelope across the gated
        portfolio is approximately $5K per
        <code class="text-xs bg-anvil/10 dark:bg-warm/10 px-1 py-0.5 rounded">.claude/rules/trauma-informed-content.md</code>.
      </p>
      <p>
        Frameworks cited across the portfolio include SAMHSA TIP 57 (2014) trauma-informed care,
        NCTSN, DSM-5, CASEL 5-competency, DIR-Floortime, Botvin Life Skills Training, Universal
        Design for Learning, CHADD, ASAN-affirming voice, Mautone 2024, and Hai 2025.
      </p>
      <p class="text-sm text-anvil/60 dark:text-warm/60">
        This is not a substitute for a clinician's recommendation for your specific kid. It's an
        editorial gate at the design-handoff level — a published commitment to the design property
        that the apps then implement.
      </p>
    </div>
  </section>

  <!-- Testimonial slot — post-launch -->
  <!-- testimonial slot — post-launch -->

  <!-- Crisis-resources footer block -->
  <section
    id="crisis-resources"
    class="bg-anvil text-warm py-16 scroll-mt-20"
    aria-label="Crisis support resources"
  >
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-brand font-bold text-2xl md:text-3xl mb-2">
        If you or your kid need help right now
      </h2>
      <p class="text-warm/70 mb-8 text-sm">
        These resources are USA-based. Outside the USA, please consult a local provider.
      </p>

      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-brand font-bold text-warm mb-3 text-lg">General crisis</h3>
          <ul class="space-y-2 text-sm text-warm/90">
            <li>
              <strong class="block">988 Suicide &amp; Crisis Lifeline</strong>
              Call or text <a href="tel:988" class="underline hover:text-spark">988</a>
            </li>
            <li>
              <strong class="block">Crisis Text Line</strong>
              Text HOME to <a href="sms:741741" class="underline hover:text-spark">741741</a>
            </li>
            <li>
              <strong class="block">Childhelp National Child Abuse Hotline</strong>
              <a href="tel:18004224453" class="underline hover:text-spark">1-800-422-4453</a>
            </li>
            <li>
              <strong class="block">RAINN National Sexual Assault Hotline</strong>
              <a href="tel:18006564673" class="underline hover:text-spark">1-800-656-4673</a>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="font-brand font-bold text-warm mb-3 text-lg">Neurodivergent-specific</h3>
          <ul class="space-y-2 text-sm text-warm/90">
            <li>
              <strong class="block">NAMI (National Alliance on Mental Illness)</strong>
              <a href="tel:18009506264" class="underline hover:text-spark">1-800-950-6264</a>
            </li>
            <li>
              <strong class="block">Autism Society Helpline</strong>
              <a href="tel:18003288476" class="underline hover:text-spark">1-800-328-8476</a>
            </li>
            <li>
              <strong class="block">CHADD (Children &amp; Adults with ADHD)</strong>
              <a href="https://chadd.org/" class="underline hover:text-spark" rel="noopener">chadd.org</a>
            </li>
            <li>
              <strong class="block">Decoding Dyslexia (state chapters)</strong>
              <a href="https://www.decodingdyslexia.net/" class="underline hover:text-spark" rel="noopener">decodingdyslexia.net</a>
            </li>
            <li>
              <strong class="block">The Trevor Project (LGBTQ+ youth)</strong>
              Call <a href="tel:18664887386" class="underline hover:text-spark">1-866-488-7386</a> or text START to <a href="sms:678678" class="underline hover:text-spark">678-678</a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Donate cross-link -->
  <section class="bg-warm dark:bg-anvil/80 py-16">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-brand font-bold text-3xl text-anvil dark:text-warm mb-4">
        Neurodivergent-affirming design takes work
      </h2>
      <p class="text-anvil/70 dark:text-warm/70 leading-relaxed max-w-prose mx-auto mb-6">
        Sensitivity reviewers, cast-design handoffs, anti-shame gating, sensory overrides,
        identity-first language — none of this is free. We're a non-profit-pending studio and our
        apps stay free forever. Help us keep building.
      </p>
      <a href="/donate" class="btn-primary">Support our work →</a>
    </div>
  </section>

  <!-- Sticky "Crisis support" affordance — visible from any scroll position -->
  <a
    href="#crisis-resources"
    class="nd-sticky-crisis fixed bottom-4 right-4 z-50 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-anvil text-warm border-2 border-warm shadow-lg hover:bg-forge focus-visible:outline focus-visible:outline-2 focus-visible:outline-spark text-sm font-bold"
    aria-label="Jump to crisis support resources"
  >
    <span aria-hidden="true">🆘</span>
    <span>Crisis support</span>
  </a>
</BaseLayout>

<style>
  /* Filter chips — neutral default + active state */
  .nd-chip {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    border: 2px solid rgb(45 45 45 / 0.15);
    background-color: rgb(255 255 255 / 0.6);
    color: rgb(45 45 45 / 0.8);
    cursor: pointer;
    transition: background-color 0.12s, border-color 0.12s, color 0.12s;
  }
  :global(.dark) .nd-chip {
    border-color: rgb(250 248 245 / 0.2);
    background-color: rgb(45 45 45 / 0.4);
    color: rgb(250 248 245 / 0.85);
  }
  .nd-chip:hover {
    border-color: #E8652B;
    color: #E8652B;
  }
  .nd-chip-active {
    background-color: #E8652B;
    border-color: #E8652B;
    color: #FAF8F5;
  }
  .nd-chip-active:hover {
    color: #FAF8F5;
  }

  /* Hide cards filtered out */
  .nd-card.nd-hidden {
    display: none;
  }

  /* Sticky crisis affordance — no animation, respects reduce-motion by default */
  .nd-sticky-crisis {
    transition: background-color 0.12s;
  }
  @media (prefers-reduced-motion: reduce) {
    .nd-sticky-crisis {
      transition: none;
    }
  }
</style>

<script>
  // Client-side filter for the app grid. No tracking, no external SDKs.
  // Default: all chips OR'd; clicking "all" resets to show every card.
  const chipsRoot = document.getElementById('nd-filter-chips');
  const grid = document.getElementById('nd-app-grid');
  if (chipsRoot && grid) {
    const buttons = Array.from(chipsRoot.querySelectorAll<HTMLButtonElement>('button[data-chip]'));
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.nd-card'));

    function applyFilter(active: string) {
      // Update aria + visual state on chips
      buttons.forEach(b => {
        const isActive = b.dataset.chip === active;
        b.classList.toggle('nd-chip-active', isActive);
        b.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });
      // Filter cards
      cards.forEach(card => {
        if (active === 'all') {
          card.classList.remove('nd-hidden');
          return;
        }
        const chips = (card.dataset.chips ?? '').split(/\s+/);
        if (chips.includes(active)) {
          card.classList.remove('nd-hidden');
        } else {
          card.classList.add('nd-hidden');
        }
      });
    }

    buttons.forEach(b => {
      b.addEventListener('click', () => {
        const chip = b.dataset.chip ?? 'all';
        applyFilter(chip);
      });
    });
  }
</script>
