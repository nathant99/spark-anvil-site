---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { apps } from '~/data/apps.generated';

// Sample slots — auto-generated previews using mature apps with rich content
const sampleSlots = [
  {
    appSlug: 'gambittales',
    title: 'GambitTales: Sir Pinwell\'s Tactical Patterns',
    grade: 'Grades 5–6',
    duration: '6 weeks · 1 hr/week',
    suggestedRate: '$15–25 per student',
    description: 'Master the pin, fork, and skewer tactical patterns through narrative chess play. Each pattern is a character archetype kids learn alongside Captain Castle.',
  },
  {
    appSlug: 'motiflab',
    title: 'MotifLab: Composition as Story',
    grade: 'Grades 4–8',
    duration: '6 weeks · 1 hr/week',
    suggestedRate: '$18–28 per student',
    description: 'Develop a 3-note motif into a full composition using narrative-arc scaffolds. Kids learn musical development the way an author develops a character.',
  },
  {
    appSlug: 'stonesong',
    title: 'StoneSong: Life and Death on the 9×9',
    grade: 'Grades 5–8',
    duration: '8 weeks · 1 hr/week',
    suggestedRate: '$15–25 per student',
    description: 'Learn Go through life-and-death character archetypes — Patient Bamboo, Hungry Crane, Master Snail, Sparring Tiger. Cultural-respect content honoring China/Korea/Japan traditions.',
  },
  {
    appSlug: 'dealtales',
    title: 'DealTales: Bridge as Partnership',
    grade: 'Grades 6–8',
    duration: '6 weeks · 1 hr/week',
    suggestedRate: '$18–28 per student',
    description: 'Learn contract bridge as a conversation between partners. Highest CASEL fit in our portfolio — partnership trust is the curriculum.',
  },
  {
    appSlug: 'haikuquest',
    title: 'HaikuQuest: Form-Scaffold Poetry',
    grade: 'Grades 4–7',
    duration: '4 weeks · 1 hr/week',
    suggestedRate: '$15–22 per student',
    description: 'Master haiku, tanka, cinquain, and limerick with syllable counters and cultural-context teaching. Cherry the cherry-blossom mascot guides every lesson.',
  },
  {
    appSlug: 'curiosityquest',
    title: 'CuriosityQuest: Cross-Subject Quests',
    grade: 'Grades 4–8',
    duration: '8 weeks · 1 hr/week',
    suggestedRate: '$15–25 per student',
    description: 'Adventure-based quizzing across math, science, ELA, and social studies. Standards-aligned to CCSS + NGSS + C3.',
  },
];
---

<BaseLayout
  title="Live Classes — Coming 2027"
  description="Small-group live classes using the Spark & Anvil apps your kid already loves. Curated by us, taught by vetted teachers. Coming Q1 2027."
>
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-12">
    <span class="inline-block px-3 py-1 mb-4 bg-spark text-anvil dark:text-warm text-xs font-bold uppercase tracking-wider rounded-full">Coming Q1 2027</span>
    <h1 class="font-brand font-bold text-4xl md:text-5xl text-anvil mb-4 dark:text-warm">
      Live classes inside the apps your kid loves.
    </h1>
    <p class="text-xl text-anvil/70 dark:text-warm/70 leading-relaxed max-w-3xl">
      Small-group live classes (4–6 students), curated by Spark &amp; Anvil and taught by vetted teachers.
      Each class uses one of our {apps.length} apps as the curriculum — your kid keeps playing the app at home,
      and the teacher reinforces concepts live once a week.
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a href="#join-waitlist" class="btn-primary">Join the parent waitlist</a>
      <a href="/teach" class="btn-secondary">For teachers →</a>
    </div>
  </section>

  <!-- Why classes -->
  <section class="bg-anvil/5 dark:bg-warm/5 py-16">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-brand font-bold text-3xl text-anvil dark:text-warm mb-8">Why pair an app with a live class?</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white dark:bg-anvil/40 rounded-xl p-6 border border-anvil/10 dark:border-warm/15">
          <h3 class="font-brand font-bold text-anvil mb-2 dark:text-warm">📈 64% completion rate</h3>
          <p class="text-sm text-anvil/70 dark:text-warm/70 leading-relaxed">
            Cohort-based courses with weekly live classes hit 64% completion vs 48% for self-paced.
            Live accountability + peer cohort = stronger learning outcomes.
          </p>
        </div>
        <div class="bg-white dark:bg-anvil/40 rounded-xl p-6 border border-anvil/10 dark:border-warm/15">
          <h3 class="font-brand font-bold text-anvil mb-2 dark:text-warm">🎯 Same app, deeper learning</h3>
          <p class="text-sm text-anvil/70 dark:text-warm/70 leading-relaxed">
            Your kid keeps the daily 10–15 minute app routine. The weekly class adds peer discussion,
            teacher feedback, and shared challenges. The app and class reinforce each other.
          </p>
        </div>
        <div class="bg-white dark:bg-anvil/40 rounded-xl p-6 border border-anvil/10 dark:border-warm/15">
          <h3 class="font-brand font-bold text-anvil mb-2 dark:text-warm">🔒 COPPA-2025 first</h3>
          <p class="text-sm text-anvil/70 dark:text-warm/70 leading-relaxed">
            We handle parental consent flows and content moderation across the whole experience.
            Your kid's data never leaves the app's on-device store.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sample slots -->
  <section class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="font-brand font-bold text-3xl text-anvil mb-2 dark:text-warm">Sample class slots</h2>
    <p class="text-anvil/60 dark:text-warm/60 mb-8">Previews from the launch catalog. The full marketplace launches Q1 2027.</p>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sampleSlots.map(slot => {
        const app = apps.find(a => a.slug === slot.appSlug);
        return (
          <div class="bg-white dark:bg-anvil/40 rounded-2xl p-6 border border-anvil/10 dark:border-warm/15 hover:shadow-md transition-shadow flex flex-col">
            <div class="flex items-center gap-3 mb-3">
              {app?.mascotPath && (
                <img src={app.mascotPath} alt={`${app.name} mascot`} class="w-12 h-12 rounded-full" style={`background-color: ${app?.heroColor || '#4A6FA5'}`} loading="lazy" />
              )}
              <div>
                <a href={`/apps/${slot.appSlug}`} class="text-xs text-anvil/50 dark:text-warm/50 hover:text-forge transition-colors">{app?.name}</a>
                <h3 class="font-brand font-bold text-anvil dark:text-warm leading-tight">{slot.title}</h3>
              </div>
            </div>
            <div class="space-y-1 mb-3">
              <p class="text-xs text-anvil/60 dark:text-warm/60"><strong>{slot.grade}</strong> · {slot.duration}</p>
              <p class="text-xs text-forge-text dark:text-forge-light font-bold">{slot.suggestedRate}</p>
            </div>
            <p class="text-sm text-anvil/70 dark:text-warm/70 leading-relaxed flex-1">{slot.description}</p>
            <p class="mt-4 text-xs text-anvil/40 dark:text-warm/40 italic">Slot opens Q1 2027</p>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Demand signal — student/parent interest registration -->
  <section id="join-waitlist" class="bg-forge/5 dark:bg-forge-light/10 border-y border-forge/20 dark:border-forge-light/30 py-16">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-brand font-bold text-3xl text-anvil mb-4 dark:text-warm">Tell us which classes interest you</h2>
      <p class="text-lg text-anvil/80 dark:text-warm/80 leading-relaxed mb-6">
        Parents and students can register interest in any class slot. <strong>Teachers see the demand signals</strong> when
        deciding which slots to bid for — so the classes that get launched first are the ones with the most family demand.
      </p>
      <a href="mailto:classes@spark-and-anvil.com?subject=Class%20interest%20%E2%80%94%20Spark%20%26%20Anvil&body=Hi%20%E2%80%94%20I%E2%80%99m%20interested%20in%20a%20class%20for%3A%0A%0AStudent%20age(s)%3A%0AInterested%20apps%2Fclasses%3A%0AOther%20preferences%20(schedule%2C%20subject%2C%20etc.)%3A%0A%0A" class="btn-primary">Register class interest</a>
      <p class="mt-4 text-sm text-anvil/60 dark:text-warm/60">
        Or <a href="/teach" class="underline hover:text-forge">teach a class yourself →</a>
      </p>
    </div>
  </section>
</BaseLayout>
