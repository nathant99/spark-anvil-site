---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { site } from '~/data/site';
---

<BaseLayout
  title="Press"
  description={`Press resources for ${site.name} — fact sheet, brand assets, and contact.`}
>
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-12">
    <h1 class="font-brand font-bold text-4xl md:text-5xl text-anvil mb-6">Press</h1>
    <p class="text-xl text-anvil/70 dark:text-warm/70 leading-relaxed">
      Fact sheet, brand assets, and contact for journalists, podcasters, educators, and
      partners writing about Spark &amp; Anvil.
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-16">
    <h2 class="font-brand font-bold text-2xl text-anvil dark:text-warm mb-4">Fact sheet</h2>
    <dl class="space-y-3 text-anvil/80 dark:text-warm/80">
      <div class="flex gap-3"><dt class="font-bold w-40">Founded</dt><dd>2025</dd></div>
      <div class="flex gap-3"><dt class="font-bold w-40">Org structure</dt><dd>501(c)(3) non-profit (pending — fiscal sponsor bridges)</dd></div>
      <div class="flex gap-3"><dt class="font-bold w-40">Headquarters</dt><dd>Remote (US)</dd></div>
      <div class="flex gap-3"><dt class="font-bold w-40">Apps</dt><dd>{site.appCount}</dd></div>
      <div class="flex gap-3"><dt class="font-bold w-40">Cast members</dt><dd>586 named characters (100% distributed-narrative coverage)</dd></div>
      <div class="flex gap-3"><dt class="font-bold w-40">Target ages</dt><dd>{site.ages}</dd></div>
      <div class="flex gap-3"><dt class="font-bold w-40">Platforms</dt><dd>iOS, iPadOS, native macOS, visionOS (select titles)</dd></div>
      <div class="flex gap-3"><dt class="font-bold w-40">Tech stack</dt><dd>Swift 6, SwiftUI, SwiftData, FoundationModels, SpriteKit, RealityKit</dd></div>
      <div class="flex gap-3"><dt class="font-bold w-40">Verticals</dt><dd>STEM, STEAM, Academics, DIR/FEDC, Special Interest</dd></div>
      <div class="flex gap-3"><dt class="font-bold w-40">Privacy</dt><dd>No ads, no in-app purchases, no tracking, on-device data only, COPPA compliant</dd></div>
      <div class="flex gap-3"><dt class="font-bold w-40">Funding model</dt><dd>Foundation grants + district licensing + individual donations (all apps remain free for individuals forever)</dd></div>
    </dl>
  </section>

  <!-- Non-profit boilerplate -->
  <section class="bg-anvil/5 dark:bg-warm/5 py-12">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-brand font-bold text-2xl text-anvil dark:text-warm mb-4">Boilerplate (for press)</h2>
      <p class="text-anvil/80 dark:text-warm/80 leading-relaxed">
        <strong>About Spark &amp; Anvil:</strong> Spark &amp; Anvil is a mission-driven non-profit
        organization (501(c)(3) status pending) building {site.appCount} educational iOS apps for kids
        ages {site.ages}. The portfolio spans STEM, STEAM, Academics, social-emotional learning, and
        special-interest verticals. All apps are free forever, ad-free, with no in-app purchases and
        no tracking. Spark &amp; Anvil pioneered <strong>distributed-narrative methodology</strong>
        (named recurring characters that embody curricular concepts; 586 characters site-visible
        across 138 apps) and <strong>pass-and-play face-to-face game modes</strong> designed for
        device-mediated family + peer co-play. Tech stack: Swift 6, SwiftUI, on-device AI via
        Apple FoundationModels.
      </p>
      <p class="mt-3 text-anvil/80 dark:text-warm/80 leading-relaxed">
        <a href="mailto:press@spark-and-anvil.com" class="underline hover:text-forge">press@spark-and-anvil.com</a>
        &middot; spark-and-anvil.com
      </p>
    </div>
  </section>

  <section class="bg-anvil/5 dark:bg-warm/5 py-16">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-brand font-bold text-2xl text-anvil dark:text-warm mb-4">Brand assets</h2>
      <ul class="space-y-3">
        <li><a href="/brand/spark-anvil-press-kit.zip" download class="text-forge-text dark:text-forge-light font-bold">📦 Full press kit (2.2 MB ZIP)</a> — logos + favicon set + palette + fact sheet</li>
        <li><a href="/brand/logomark.png" download class="text-forge-text dark:text-forge-light font-bold">Logomark (PNG, 1024×1024)</a></li>
        <li><a href="/brand/lockup.png" download class="text-forge-text dark:text-forge-light font-bold">Full lockup (PNG, 1024×1024)</a></li>
        <li><a href="/brand/og-image.png" download class="text-forge-text dark:text-forge-light font-bold">Social share image (1200×630)</a></li>
      </ul>
      <p class="text-anvil/70 dark:text-warm/70 mt-6 leading-relaxed">
        Brand colors: Forge Orange <code class="text-forge-text dark:text-forge-light">#E8652B</code>,
        Anvil Charcoal <code class="text-anvil dark:text-warm">#2D2D2D</code>,
        Spark Gold <code class="text-spark">#FFBE2E</code>.
      </p>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-6 py-16">
    <h2 class="font-brand font-bold text-2xl text-anvil mb-4">Contact</h2>
    <p class="text-anvil/80 dark:text-warm/80 leading-relaxed">
      Press inquiries: <a href={`mailto:${site.press}`}>{site.press}</a>.
      <br />
      General: <a href={`mailto:${site.email}`}>{site.email}</a>.
    </p>
  </section>
</BaseLayout>
