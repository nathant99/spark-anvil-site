---
import { nav, site } from '~/data/site';

const { pathname } = Astro.url;
---

<header class="border-b border-anvil/10 bg-warm/80 backdrop-blur sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3" aria-label={`${site.name} home`}>
      <img src="/brand/lockup.png" alt={site.name} class="h-10 w-auto" />
    </a>
    <nav class="hidden md:flex items-center gap-6" aria-label="Primary">
      {nav.slice(1).map(item => (
        <a
          href={item.href}
          class={`text-sm font-medium hover:text-forge transition-colors ${
            pathname === item.href ? 'text-forge' : 'text-anvil'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <a href="/apps" class="md:hidden text-sm font-bold text-forge-text">Apps →</a>
  </div>
</header>
