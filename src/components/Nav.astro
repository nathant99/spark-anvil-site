---
import { nav, site } from '~/data/site';

const { pathname } = Astro.url;
const items = nav.slice(1);  // skip "Home" — logo links there

type NavChild = { href: string; label: string };
type NavItem = { href: string; label: string; cta?: boolean; badge?: string; overflow?: boolean; children?: NavChild[] };

// Active matching — supports prefix (e.g., /apps/<slug> activates /apps) but not "/" alone.
// "/" must match exactly to avoid every route activating the Home link.
function isActive(href: string, current: string): boolean {
  if (href === '/') return current === '/';
  if (current === href) return true;
  return current.startsWith(href + '/');
}

// Desktop render order: visible non-CTA links → "More ▾" overflow popover → CTA at the right edge.
const visibleNonCta = (items as NavItem[]).filter(item => !item.overflow && !item.cta);
const overflowItems = (items as NavItem[]).filter(item => !!item.overflow);
const ctaItems = (items as NavItem[]).filter(item => !!item.cta);
const hasOverflow = overflowItems.length > 0;
const overflowActive = overflowItems.some(item => isActive(item.href, pathname));
---

<!--
  Liquid-Glass-inspired sticky nav (ADR-014, Round 149 #580, 2026-05-29).
  Pattern: semi-opaque brand background + medium backdrop blur + thin bottom border + subtle saturate.
  Falls back to solid `bg-warm` / `bg-anvil` under `prefers-reduced-transparency` via `nav-glass` class in global.css.
  Hybrid policy: chunky-cartoon brand register stays primary; this is the only always-on glass surface.
-->
<header class="nav-glass border-b border-anvil/10 dark:border-warm/15 bg-warm/85 dark:bg-anvil/85 backdrop-blur-md backdrop-saturate-150 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3" aria-label={`${site.name} home`}>
      <img src="/brand/lockup.png" alt={site.name} class="h-20 md:h-24 w-auto" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-5" aria-label="Primary">
      {visibleNonCta.map(item => {
        const active = isActive(item.href, pathname) || (item.children?.some(c => isActive(c.href, pathname)));
        if (item.children) {
          return (
            <div class="relative group">
              <button
                type="button"
                class={`flex items-center gap-1 text-sm transition-colors ${
                  active
                    ? 'text-forge dark:text-forge-light font-bold border-b-2 border-forge pb-0.5'
                    : 'text-anvil dark:text-warm font-medium border-b-2 border-transparent pb-0.5 hover:text-forge dark:hover:text-forge-light'
                }`}
                aria-haspopup="true"
              >
                {item.label}
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="3 4.5 6 7.5 9 4.5"></polyline>
                </svg>
              </button>
              <div class="absolute right-0 top-full mt-1 min-w-[180px] bg-warm dark:bg-anvil border border-anvil/10 dark:border-warm/15 rounded-lg shadow-md p-1 invisible opacity-0 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100 transition-opacity">
                {item.children.map(child => (
                  <a
                    href={child.href}
                    aria-current={isActive(child.href, pathname) ? 'page' : undefined}
                    class={`block px-3 py-2 rounded text-sm font-medium ${
                      isActive(child.href, pathname)
                        ? 'bg-forge/10 dark:bg-forge-light/15 text-forge dark:text-forge-light font-bold'
                        : 'text-anvil dark:text-warm hover:bg-anvil/5 dark:hover:bg-warm/10'
                    }`}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          );
        }
        return (
          <a
            href={item.href}
            aria-current={active ? 'page' : undefined}
            class={`inline-flex items-center gap-1.5 text-sm transition-colors ${
              active
                ? 'text-forge dark:text-forge-light font-bold border-b-2 border-forge pb-0.5'
                : 'text-anvil dark:text-warm font-medium border-b-2 border-transparent pb-0.5 hover:text-forge dark:hover:text-forge-light'
            }`}
          >
            {item.label}
            {item.badge && (
              <span class="px-1.5 py-0.5 bg-forge text-warm text-[10px] font-bold uppercase tracking-wider rounded-full leading-none">
                {item.badge}
              </span>
            )}
          </a>
        );
      })}

      {hasOverflow && (
        <div class="relative group">
          <button
            type="button"
            class={`flex items-center gap-1 text-sm transition-colors ${
              overflowActive
                ? 'text-forge dark:text-forge-light font-bold border-b-2 border-forge pb-0.5'
                : 'text-anvil dark:text-warm font-medium border-b-2 border-transparent pb-0.5 hover:text-forge dark:hover:text-forge-light'
            }`}
            aria-haspopup="true"
            aria-label="More navigation links"
          >
            More
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="3 4.5 6 7.5 9 4.5"></polyline>
            </svg>
          </button>
          <div class="absolute right-0 top-full mt-1 min-w-[180px] bg-warm dark:bg-anvil border border-anvil/10 dark:border-warm/15 rounded-lg shadow-md p-1 invisible opacity-0 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100 transition-opacity">
            {overflowItems.map(item => (
              <a
                href={item.href}
                aria-current={isActive(item.href, pathname) ? 'page' : undefined}
                class={`flex items-center gap-1.5 px-3 py-2 rounded text-sm ${
                  isActive(item.href, pathname)
                    ? 'bg-forge/10 dark:bg-forge-light/15 text-forge dark:text-forge-light font-bold'
                    : 'text-anvil dark:text-warm font-medium hover:bg-anvil/5 dark:hover:bg-warm/10'
                }`}
              >
                {item.label}
                {item.badge && (
                  <span class="px-1.5 py-0.5 bg-forge text-warm text-[10px] font-bold uppercase tracking-wider rounded-full leading-none">
                    {item.badge}
                  </span>
                )}
              </a>
            ))}
          </div>
        </div>
      )}

      {ctaItems.map(item => (
        <a
          href={item.href}
          class="px-4 py-2 bg-forge hover:bg-forge/90 text-warm text-sm font-bold rounded-full transition-colors"
          aria-current={isActive(item.href, pathname) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger button -->
    <button
      id="mobile-nav-toggle"
      class="md:hidden p-2 -mr-2 text-anvil dark:text-warm"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-nav-drawer"
    >
      <svg id="mobile-nav-icon-open" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
      <svg id="mobile-nav-icon-close" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="hidden" aria-hidden="true">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="18" y1="6" x2="6" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile drawer (slides down below the sticky header) -->
  <!-- Mobile shows ALL nav items inline (no overflow popover) — hamburger menu is already a disclosure. -->
  <nav
    id="mobile-nav-drawer"
    class="md:hidden hidden border-t border-anvil/10 dark:border-warm/15 bg-warm dark:bg-anvil"
    aria-label="Mobile primary"
  >
    <ul class="max-w-6xl mx-auto px-6 py-4 space-y-1">
      {(items as NavItem[]).map(item => {
        if (item.children) {
          return (
            <li>
              <details class="group">
                <summary class={`flex items-center justify-between px-3 py-3 rounded-lg font-brand font-bold text-lg cursor-pointer ${
                  item.children.some(c => isActive(c.href, pathname))
                    ? 'bg-forge/10 dark:bg-forge-light/15 text-forge dark:text-forge-light'
                    : 'text-anvil dark:text-warm'
                }`}>
                  {item.label}
                  <svg width="14" height="14" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform" aria-hidden="true">
                    <polyline points="3 4.5 6 7.5 9 4.5"></polyline>
                  </svg>
                </summary>
                <ul class="pl-3 mt-1 space-y-1">
                  {item.children.map(child => (
                    <li>
                      <a
                        href={child.href}
                        aria-current={isActive(child.href, pathname) ? 'page' : undefined}
                        class={`block px-3 py-2 rounded-lg text-base ${
                          isActive(child.href, pathname)
                            ? 'bg-forge/10 dark:bg-forge-light/15 text-forge dark:text-forge-light font-bold'
                            : 'text-anvil/80 dark:text-warm/80 hover:bg-anvil/5 dark:hover:bg-warm/10'
                        }`}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            </li>
          );
        }
        const active = isActive(item.href, pathname);
        return (
          <li>
            <a
              href={item.href}
              aria-current={active ? 'page' : undefined}
              class={`flex items-center gap-2 px-3 py-3 rounded-lg font-brand font-bold text-lg ${
                item.cta
                  ? 'bg-forge text-warm hover:bg-forge/90'
                  : active
                  ? 'bg-forge/10 dark:bg-forge-light/15 text-forge dark:text-forge-light border-l-4 border-forge -ml-1 pl-2'
                  : 'text-anvil dark:text-warm hover:bg-anvil/5 dark:bg-warm/5 dark:hover:bg-warm/10'
              }`}
            >
              <span>{item.label}</span>
              {item.badge && (
                <span class="px-2 py-0.5 bg-forge text-warm text-xs font-bold uppercase tracking-wider rounded-full">
                  {item.badge}
                </span>
              )}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-nav-toggle');
  const drawer = document.getElementById('mobile-nav-drawer');
  const iconOpen = document.getElementById('mobile-nav-icon-open');
  const iconClose = document.getElementById('mobile-nav-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = drawer?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });

  // Close drawer when a leaf link is tapped (mobile navigation pattern)
  drawer?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      drawer.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      btn?.setAttribute('aria-label', 'Open navigation menu');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
