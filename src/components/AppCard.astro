---
interface Props {
  slug: string;
  name: string;
  tagline: string;
  vertical: string;
  heroColor: string;
}

const { slug, name, tagline, vertical, heroColor } = Astro.props;
---

<a
  href={`/apps/${slug}`}
  class="group block rounded-2xl overflow-hidden border border-anvil/10 bg-white hover:shadow-lg hover:-translate-y-1 transition-all"
>
  <div
    class="h-32 flex items-center justify-center"
    style={`background-color: ${heroColor}`}
  >
    <img
      src={`/apps/${slug}/icon.png`}
      alt={`${name} icon`}
      class="w-20 h-20 rounded-2xl shadow-md"
      loading="lazy"
      onerror="this.style.display='none'"
    />
  </div>
  <div class="p-5">
    <div class="flex items-center justify-between mb-2">
      <h3 class="font-brand font-bold text-lg text-anvil group-hover:text-forge transition-colors">
        {name}
      </h3>
      <span class="text-xs uppercase tracking-wider text-anvil/50 font-medium">
        {vertical}
      </span>
    </div>
    <p class="text-sm text-anvil/70 leading-relaxed">{tagline}</p>
  </div>
</a>
