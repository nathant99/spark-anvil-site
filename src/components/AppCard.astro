---
interface Props {
  slug: string;
  name: string;
  tagline: string;
  vertical: string;
  heroColor: string;
  iconPath?: string | null;
  mascotPath?: string | null;
  implementing?: boolean;
  distributedNarrative?: boolean;
}

const { slug, name, tagline, vertical, heroColor, iconPath, mascotPath, implementing = true, distributedNarrative = false } = Astro.props;
---

<a
  href={`/apps/${slug}`}
  class="group block rounded-2xl overflow-hidden border border-anvil/10 dark:border-warm/15 bg-white dark:bg-anvil/40 hover:shadow-lg hover:-translate-y-1 transition-all relative"
>
  <div
    class="h-32 flex items-center justify-center relative overflow-hidden"
    style={`background-color: ${heroColor}`}
  >
    {iconPath && (
      <img
        src={iconPath}
        alt={`${name} icon`}
        class="w-20 h-20 rounded-2xl shadow-md relative z-10"
        loading="lazy"
        onerror="this.style.display='none'"
      />
    )}
    {!iconPath && (
      <div class="w-20 h-20 rounded-2xl bg-white/20 dark:bg-warm/10 flex items-center justify-center text-white/70 text-xs font-bold">
        {name.slice(0, 2).toUpperCase()}
      </div>
    )}
    {mascotPath && (
      <img
        src={mascotPath}
        alt={`${name} mascot`}
        class="absolute -bottom-2 -right-2 w-16 h-16 object-contain"
        loading="lazy"
        onerror="this.style.display='none'"
      />
    )}
  </div>
  <div class="p-5">
    <div class="flex items-center justify-between mb-2">
      <h3 class="font-brand font-bold text-lg text-anvil dark:text-warm group-hover:text-forge dark:group-hover:text-forge-light transition-colors">
        {name}
      </h3>
      <span class="text-xs uppercase tracking-wider text-anvil/50 dark:text-warm/50 font-medium">
        {vertical}
      </span>
    </div>
    <p class="text-sm text-anvil/70 dark:text-warm/70 leading-relaxed line-clamp-4">{tagline}</p>
    <div class="flex flex-wrap gap-2 mt-3">
      {distributedNarrative && (
        <a
          href="/method"
          class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full bg-forge/10 dark:bg-forge-light/15 text-forge-text dark:text-forge-light font-bold uppercase tracking-wider hover:bg-forge/20 dark:bg-forge-light/25 dark:hover:bg-forge-light/25 transition-colors"
          title="Uses distributed-narrative methodology — characters embody the curriculum"
          onclick="event.stopPropagation()"
        >
          <span aria-hidden="true">●</span> Distributed-Narrative
        </a>
      )}
      {!implementing && (
        <span class="inline-block text-xs text-anvil/40 dark:text-warm/40 italic">Coming soon</span>
      )}
    </div>
  </div>
</a>
