---
import { site } from '~/data/site';
---

<footer class="border-t border-anvil/10 dark:border-warm/15 bg-warm dark:bg-anvil mt-24">
  <div class="max-w-6xl mx-auto px-6 py-12 grid gap-8 md:grid-cols-5">
    <div class="md:col-span-2">
      <img src="/brand/logomark.png" alt={site.name} class="h-16 w-16 mb-3" />
      <p class="text-sm text-anvil/70 dark:text-warm/70 max-w-xs mb-4">
        {site.description}
      </p>
      <p class="text-xs text-anvil/60 dark:text-warm/60 leading-relaxed">
        <strong>501(c)(3) non-profit (pending)</strong> — donations route through our
        fiscal sponsor and are tax-deductible from day one. <a href="/donate" class="underline hover:text-forge">Support the mission →</a>
      </p>
    </div>
    <div>
      <h3 class="font-brand font-bold text-sm mb-3">Apps</h3>
      <ul class="space-y-2 text-sm">
        <li><a href="/apps">All apps</a></li>
        <li><a href="/cast">Cast</a></li>
        <li><a href="/mascots">Mascots</a></li>
        <li><a href="/play-together">Play Together</a></li>
        <li><a href="/method">Method</a></li>
      </ul>
    </div>
    <div>
      <h3 class="font-brand font-bold text-sm mb-3">Organization</h3>
      <ul class="space-y-2 text-sm">
        <li><a href="/mission">Mission</a></li>
        <li><a href="/impact">Impact</a></li>
        <li><a href="/board">Board</a></li>
        <li><a href="/annual-report">Annual Report</a></li>
        <li><a href="/donate" class="font-bold text-forge">Donate</a></li>
      </ul>
    </div>
    <div>
      <h3 class="font-brand font-bold text-sm mb-3">Connect</h3>
      <ul class="space-y-2 text-sm">
        <li><a href="/about">About</a></li>
        <li><a href="/for-parents">For Parents</a></li>
        <li><a href="/for-educators">For Educators</a></li>
        <li><a href="/press">Press</a></li>
        <li><a href="/privacy">Privacy</a></li>
        <li><a href="/terms">Terms</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-anvil/10 dark:border-warm/15">
    <div class="max-w-6xl mx-auto px-6 py-6 flex flex-wrap items-center justify-between gap-4 text-xs text-anvil/60 dark:text-warm/60">
      <span>© {new Date().getFullYear()} {site.name}. Made with care for ages {site.ages}.</span>
      <span>501(c)(3) non-profit (pending) · Free forever · No ads · No tracking · COPPA compliant</span>
    </div>
  </div>
</footer>
