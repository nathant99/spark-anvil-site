---
import '~/styles/global.css';
import Nav from '~/components/Nav.astro';
import Footer from '~/components/Footer.astro';
import { site } from '~/data/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = site.name,
  description = site.description,
  ogImage = site.ogImage,
} = Astro.props;

const pageTitle = title === site.name ? `${site.name} — ${site.tagline}` : `${title} — ${site.name}`;
const canonicalUrl = new URL(Astro.url.pathname, site.url).toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/brand/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/brand/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/brand/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/brand/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#E8652B" />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="preload" as="font" type="font/woff2" href="/fonts/Geist-Variable.woff2" crossorigin />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, site.url).toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, site.url).toString()} />

    <meta name="generator" content={Astro.generator} />

    <!-- Plausible Analytics (privacy-first, no cookies, COPPA-safe) -->
    <!-- Activates only in production, behind env flag. -->
    {import.meta.env.PROD && (
      <script defer data-domain="spark-and-anvil.com" src="https://plausible.io/js/script.js"></script>
    )}

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: site.name,
      url: site.url,
      logo: new URL('/brand/logomark.png', site.url).toString(),
      description: site.description,
      email: site.email,
    })} />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
